            self.OptionFrames[optionText] = optionFrame

            optionFrame.MouseEnter:Connect(function()
                if not (self.Multi and table.find(self.SelectedValues, optionText) or self.Value == optionText) then
                    Menu:Tween(optionFrame, {
                        TextColor3 = Color3.fromRGB(111, 111, 111),
                    })
                end
            end)
            optionFrame.MouseLeave:Connect(function()
