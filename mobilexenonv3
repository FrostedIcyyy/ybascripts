        function notification.Show(self)
            if self.isVisible then
                return
            end

            self.isVisible = true
            self.startTime = tick()

            table.insert(Menu.NotificationSystem.notificationsList, self)

            Menu.NotificationSystem.notifications[self.id] = self

            task.wait()

            local TweenService = game:GetService'TweenService'

            TweenService:Create(self.frame, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {BackgroundTransparency = 0}):Play()
            TweenService:Create(self.stroke, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Transparency = 0.99}):Play()
            RepositionNotifications()
            TweenService:Create(self.progressBar, TweenInfo.new(self.duration, Enum.EasingStyle.Linear), {
                Size = UDim2.new(0, 0, 1, 0),
            }):Play()
            task.delay(self.duration, function()
                if self.isVisible then
                    self:Hide()
                end
            end)
        end
        function notification.Hide(self)
            if not self.isVisible then
                return
            end

            self.isVisible = false

            local TweenService = game:GetService'TweenService'

            TweenService:Create(self.frame, TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {BackgroundTransparency = 1}):Play()
            TweenService:Create(self.stroke, TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {Transparency = 1}):Play()
            TweenService:Create(self.frame, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
                Position = UDim2.new(1, 300, 1, self.frame.Position.Y.Offset),
            }):Play()
            task.spawn(function()
                task.wait(0.15)

                for i, notif in ipairs(Menu.NotificationSystem.notificationsList)do
                    if notif.id == self.id then
                        table.remove(Menu.NotificationSystem.notificationsList, i)

                        break
                    end
                end

                RepositionNotifications()
                task.wait(0.15)

                if self.frame and self.frame.Parent then
                    self.frame:Destroy()
                end

                Menu.NotificationSystem.notifications[self.id] = nil
            end)
        end
        function notification.Update(self, newTitle, newContent)
            if newTitle then
                self.title = newTitle

                if self.titleLabel then
                    self.titleLabel.Text = newTitle
                end
            end
            if newContent then
                self.content = newContent

                if self.contentLabel then
                    self.contentLabel.Text = newContent
                end
            end
        end

        DismissButton.InputBegan:Connect(function(input)
            if isClick(input) then
                notification:Hide()
            end
        end)

        return notification
    end
