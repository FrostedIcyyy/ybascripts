function TeleportToBallCarrier()
    local character = game:GetService('Players').LocalPlayer.Character
    local Opp = findOpp()

    if not character or not Opp then
        return
    end

    local hrp = character:FindFirstChild('HumanoidRootPart')
    local oppHrp = Opp:FindFirstChild('HumanoidRootPart')

    if not hrp or not oppHrp then
        return
    end

    hrp.CFrame = oppHrp.CFrame + Vector3.new(0.1, 0.1, 0.1)
end
function TeleportWithinDistance()
    local character = game:GetService('Players').LocalPlayer.Character
    local Opp = findOpp()

    if not character or not Opp then
        return
    end

    local hrp = character:FindFirstChild('HumanoidRootPart')
    local oppHrp = Opp:FindFirstChild('HumanoidRootPart')

    if not hrp or not oppHrp then
        return
    end

    local Distance = (hrp.Position - oppHrp.Position).Magnitude
    local Radius = Tyrant.Physics.Teleportation.ClickTackleRadius

    if Distance <= Radius then
        TeleportToBallCarrier()
    end
end

