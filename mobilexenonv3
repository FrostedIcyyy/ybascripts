task.defer(function()
    task.wait(1)

    if not isfile('startup_config.tyrant') then
        return
    end

    local autoCfgName = readfile('startup_config.tyrant')

    if not autoCfgName or autoCfgName == '' then
        return
    end

    local path = autoCfgName .. '.tyrantconfig'

    if not isfile(path) then
        return
    end

    local HS = game:GetService('HttpService')
    local ok, decoded = pcall(function()
        return HS:JSONDecode(readfile(path))
    end)

    if not ok or type(decoded) ~= 'table' then
        return
    end
    if decoded.__MenuAccent and type(decoded.__MenuAccent) == 'string' and #decoded.__MenuAccent == 6 then
        pcall(Menu.ChangeAccent, Menu, Color3.fromHex(decoded.__MenuAccent))
    end

    local toggleByFlag = {}

    for _, t in ipairs(Menu.Toggles)do
        if t.Flag then
            toggleByFlag[t.Flag] = t
        end
    end
    for flag, value in pairs(decoded)do
        if flag == '__MenuAccent' or flag == 'ConfigName' then
            continue
        end
        if type(value) == 'string' and #value == 6 and value:match('^%x+$') then
            value = Color3.fromHex(value)
        end

        Menu.Config.Configs[flag] = value

        if toggleByFlag[flag] then
            pcall(function()
                toggleByFlag[flag]:Set(value)
            end)
        end

        local setter = Menu.Config.Setters[flag]

        if setter then
            pcall(setter, value)
        end
    end

    Menu:ShowNotification({
        title = 'Startup Config Loaded',
        content = autoCfgName,
        duration = 3,
    })
end)
