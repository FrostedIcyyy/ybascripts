		local b = to.Y - from.Y
		local c = xMeters - from.Y

		local discriminant = b * b - 4 * a * c
		if discriminant < 0 then
			return nil
		end

		local t1 = (-b + math.sqrt(discriminant)) / (2 * a)
		local t2 = (-b - math.sqrt(discriminant)) / (2 * a)

		local t = math.max(t1, t2)
		return t
