game:GetService('Workspace').ChildAdded:Connect(function(ball)
    task.wait()

    if ball.Name ~= 'Football' then
        return
    end
    if not ball:IsA('BasePart') then
        return
    end
    if Tyrant.Visuals.FootballVisuals.RemoveBallTrail and ball:FindFirstChildWhichIsA('Trail') then
        ball:FindFirstChildWhichIsA('Trail').Enabled = false
    end

    task.spawn(function()
        if not Tyrant.Visuals.OptimalJump.Enabled then
            return
        end

        local initalVelocity = ball.AssemblyLinearVelocity
        local optimalPosition = Vector3.zero
        local currentPosition = ball.Position
        local t = 0

        while true do
            task.wait()

            t += 0.05
            initalVelocity += Vector3.new(0, -1.4000000000000001, 0)
            currentPosition += initalVelocity * 0.05

            local raycastParams = RaycastParams.new()

            raycastParams.FilterDescendantsInstances = {
                game:GetService('Workspace'):FindFirstChild('Models'),
            }
            raycastParams.FilterType = Enum.RaycastFilterType.Include

            local ray = game:GetService('Workspace'):Raycast(currentPosition, Vector3.new(0, Tyrant.Visuals.OptimalJump.Type == 'Jump' and -13 or -15, 0), raycastParams)
            local antiCrashRay = game:GetService('Workspace'):Raycast(currentPosition, Vector3.new(0, -500, 0), raycastParams)

            if ray and t > 0.75 then
                optimalPosition = ray.Position + Vector3.new(0, 2, 0)

                break
            end
            if not antiCrashRay then
                optimalPosition = currentPosition

                break
            end
        end

        local part = Instance.new('Part')

        part.Anchored = true
        part.Material = Enum.Material.Neon
        part.Size = Vector3.new(1.5, 1.5, 1.5)
        part.Position = optimalPosition
        part.CanCollide = false
        part.Parent = workspace
        part.Color = Color3.fromRGB(73, 57, 255)

        repeat
            task.wait()
        until ball.Parent ~= workspace

        part:Destroy()
    end)
    task.spawn(function()
        if not Tyrant.Visuals.FootballVisuals.VisualizeBallPath then
            return
        end

        local waited = 0

        while ball.AssemblyLinearVelocity.Magnitude < 1 and waited < 15 do
            if ball.Parent ~= workspace then
                return
            end

            task.wait()

            waited += 1
        end

        if ball.Parent ~= workspace or ball.AssemblyLinearVelocity.Magnitude < 1 then
            return
        end

        local initalVelocity = ball.AssemblyLinearVelocity
        local a0, a1 = Instance.new('Attachment'), Instance.new('Attachment')

        a0.Parent = workspace.Terrain
        a1.Parent = workspace.Terrain

        local beam = Instance.new('Beam')

        beam.Parent = workspace.Terrain
        beam.Attachment0 = a0
        beam.Attachment1 = a1
        beam.Segments = 500
        beam.Transparency = NumberSequence.new(0)
        beam.Color = ColorSequence.new(BeamColor)
        beam.Texture = 'rbxassetid://90867804027693'
        beam.TextureSpeed = 0
        beam.TextureLength = 0
        beam.TextureMode = Enum.TextureMode.Stretch
        beam.Width0 = 5
        beam.Width1 = 5
        beam.Brightness = 3
        beam.LightEmission = 5
        beam.LightInfluence = 0

        local function cleanupBeam()
            pcall(function()
                a0:Destroy()
            end)
            pcall(function()
                a1:Destroy()
            end)
            pcall(function()
                beam:Destroy()
            end)
        end

        local g = Vector3.new(0, -28, 0)
        local x0 = ball.Position
        local v0 = initalVelocity
        local ok, curve0, curve1, cf1, cf2 = pcall(beamProjectile, g, v0, x0, 5)

        if not ok then
            cleanupBeam()

            return
        end

        beam.CurveSize0 = curve0
        beam.CurveSize1 = curve1
        a0.CFrame = a0.Parent.CFrame:inverse() * cf1
        a1.CFrame = a1.Parent.CFrame:inverse() * cf2

        local connection

        connection = ball.Touched:Connect(function(hit)
            if hit:IsA('BasePart') and hit.Anchored then
                connection:Disconnect()
                task.wait(0.5)
                cleanupBeam()
            end
        end)

        repeat
            task.wait()
        until ball.Parent ~= workspace or not ball.Parent

        pcall(function()
            connection:Disconnect()
        end)
        cleanupBeam()
    end)
end)
