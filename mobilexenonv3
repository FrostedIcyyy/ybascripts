		local function createParticle()
			local particle = Instance.new("Frame")
			particle.BackgroundColor3 = Color3.fromRGB(106, 106, 106)
			particle.BackgroundTransparency = 0.4
			particle.BorderSizePixel = 0
			particle.AnchorPoint = Vector2.new(0.5, 0.5)
			particle.Size = UDim2.fromOffset(2, 2)
			particle.ZIndex = 2
			particle.Parent = ParticleContainer
			return particle
		end

		local function animateParticle(fromPos)
			local particle = createParticle()
			local randY = math.random(-8, 8)
			particle.Position = fromPos + UDim2.fromOffset(0, randY)
			local speed = math.random(15, 25) / 100
			local distance = math.random(10, 18)
			local size = math.random(1, 3)
			particle.Size = UDim2.fromOffset(size, size)
			local fadeOut = TweenService:Create(particle, TweenInfo.new(speed * 1.5, Enum.EasingStyle.Quad), {
				BackgroundTransparency = 1,
				Position = particle.Position - UDim2.fromOffset(distance, randY / 2),
			})
			fadeOut:Play()
			fadeOut.Completed:Connect(function()
				particle:Destroy()
			end)
		end

		local function createParticleBurst(fromPos)
			for i = 1, math.random(4, 6) do
				animateParticle(fromPos)
			end
		end

		local function emitParticles(initialPos, finalPos)
			local distance = (finalPos.X.Offset - initialPos.X.Offset)
			local steps = math.floor(distance / 3)
			for i = 1, steps do
				local currentPos = UDim2.new(1, initialPos.X.Offset + (i * (distance / steps)), 0.5, 0)
				task.delay(i * 0.02, function()
					createParticleBurst(currentPos)
				end)
			end
		end

		local isHovered = false

		local function buttonHoverStart()
			isHovered = true
			if isAnimating then
				return
			end
			TweenService:Create(arrow, TweenInfo.new(0.3, Enum.EasingStyle.Back), {
				Position = UDim2.new(1, -20, 0.5, 0),
			}):Play()
		end

		local function buttonHoverEnd()
			isHovered = false
			if not isAnimating then
				TweenService:Create(arrow, TweenInfo.new(0.2), {
					Position = UDim2.new(1, -15, 0.5, -1),
				}):Play()
			end
		end

		local function buttonClick()
			if isAnimating then
				return
			end
			isAnimating = true
			local initialPos = arrow.Position
			local finalPos = UDim2.new(1, 15, 0.5, 0)
			local launchTween =
				TweenService:Create(arrow, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
					Position = finalPos,
				})
			launchTween:Play()
			emitParticles(initialPos, finalPos)
			updateTitleColor(true)
			Button.Callback()
			task.delay(0.4, function()
				if not isHovered then
					TweenService:Create(arrow, TweenInfo.new(0.2), {
						Position = UDim2.new(1, -10, 0.5, -1),
					}):Play()
				else
					TweenService:Create(arrow, TweenInfo.new(0.2), {
						Position = UDim2.new(1, -15, 0.5, 0),
					}):Play()
				end
				updateTitleColor(false)
				isAnimating = false
			end)
		end
		if active then
			buttonframe.MouseEnter:Connect(buttonHoverStart)
			buttonframe.MouseLeave:Connect(buttonHoverEnd)
			buttonframe.MouseButton1Click:Connect(buttonClick)
		else
			buttonframe.MouseButton1Click:Connect(function()
				Library:Notify("You must be on a non-limited (100% supported) executor to use this this feature.\nCheck the list at tyranthub.net/executors")
			end)
		end
		return Button
	end

