        Dropdown.Open = function(self)
            if self.IsOpen then
                return
            end

            self.IsOpen = true
            DropdownList.Visible = true
            DropdownList.ZIndex = self._ZIndex
            self.optionHolder.ZIndex = self._ZIndex

            Menu:Tween(self.dropdownIcon, {Rotation = 180})
            Menu:Tween(DropdownName, {
                TextColor3 = Color3.fromRGB(204, 204, 204),
            })
            TweenService:Create(dropdownScale, TweenInfo.new(0.2, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1}):Play()
            TweenService:Create(DropdownList, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {BackgroundTransparency = 0}):Play()
            TweenService:Create(dropdownStroke, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Transparency = 0}):Play()

            DropdownList.Size = UDim2.new(0, 20, 0, 0)

            local targetSize = UDim2.new(0, 20, 0, self.optionHolder.AbsoluteSize.Y + 10)

            Menu:Tween(DropdownList, {Size = targetSize})

            outsideClickConnection = UserInputService.InputBegan:Connect(function(input)
                if isClick(input) then
                    local mousePos = input.Position
                    local dropPos = dropdownframeeeeee.AbsolutePosition
                    local dropSize = dropdownframeeeeee.AbsoluteSize
                    local listPos = DropdownList.AbsolutePosition
                    local listSize = DropdownList.AbsoluteSize
                    local outsideMain = mousePos.X < dropPos.X or mousePos.X > dropPos.X + dropSize.X or mousePos.Y < dropPos.Y or mousePos.Y > dropPos.Y + dropSize.Y
                    local outsideList = mousePos.X < listPos.X or mousePos.X > listPos.X + listSize.X or mousePos.Y < listPos.Y or mousePos.Y > listPos.Y + listSize.Y

                    if outsideMain and outsideList then
                        self:Close()
                    end
                end
            end)
        end
        Dropdown.Close = function(self)
            if not self.IsOpen then
                return
            end

            self.IsOpen = false

            if outsideClickConnection then
                outsideClickConnection:Disconnect()

                outsideClickConnection = nil
            end

            Menu:Tween(self.dropdownIcon, {Rotation = 0})
            Menu:Tween(DropdownName, {
                TextColor3 = Color3.fromRGB(62, 62, 69),
