local originalMaterials = {}

GraphicsMiscVisualsSection:Toggle{
    Name = 'Low Graphics',
    Description = 'Sets graphics to low textures.',
    Default = false,
    Flag = 'LowGraphics',
    Callback = function(value)
        Tyrant.Visuals.Others.LowGraphics = value

        if Tyrant.Visuals.Others.LowGraphics then
            for _, v in next, game:GetService('Workspace'):GetDescendants()do
                if v:IsA('Part') and v.Material then
                    if not originalMaterials[v] then
                        originalMaterials[v] = v.Material
                        v.Material = Enum.Material.SmoothPlastic
                    end
                end
            end
        else
            for v, mat in next, originalMaterials do
                if v and v:IsA('Part') then
                    v.Material = mat
                end

                originalMaterials[v] = nil
            end
        end
    end,
}
GraphicsMiscVisualsSection:Toggle{
    Name = 'Hide Stadium',
    Description = 'Hides the football stadium.',
    Default = false,
    Flag = 'HideStadium',
    Callback = function(value)
        local Models = game:GetService('Workspace'):FindFirstChild('Models')
        local Stadium = Models and Models:FindFirstChild('Stadium')
        local ReplicatedStorageStadium = game:GetService('ReplicatedStorage'):FindFirstChild('Stadium')

        if value then
            if Stadium then
                Stadium.Parent = game:GetService('ReplicatedStorage')
            end
        else
            if ReplicatedStorageStadium then
                ReplicatedStorageStadium.Parent = Models
            end
        end
    end,
}

