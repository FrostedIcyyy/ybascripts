function Library.SetTheme(self, themeName)
	if not self.Theme[themeName] then
		warn("theme is invalid.......:", themeName)
		return
	end

	self.SelectedTheme = themeName

	for object, properties in pairs(self.ThemeObjects) do
		if object and object:IsA("Instance") then
			for property, themeKey in pairs(properties) do
				local success, result = pcall(function()
					if typeof(themeKey) == "function" then
						local value = themeKey()
						object[property] = value
					else
						object[property] = self.Theme[self.SelectedTheme][themeKey]
					end
				end)

				if not success then
					warn("failed", result)
					warn("object:", object:GetFullName())
				end
			end
		end
	end
end

function Library.TrackThemeObject(self, object, propertyTable)
	self.ThemeObjects[object] = propertyTable
	if self.SelectedTheme then
		for property, themeKey in pairs(propertyTable) do
			local success, result = pcall(function()
				if typeof(themeKey) == "function" then
					local value = themeKey()
					object[property] = value
				else
					object[property] = self.Theme[self.SelectedTheme][themeKey]
				end
			end)

			if not success then
				warn("failed", result)
				warn("object:", object:GetFullName())
			end
		end
	end
end

