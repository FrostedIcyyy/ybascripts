    local renderedMessageIds = {}

    local function refresh_chat()
        local messages = fetch_messages()

        for i = #messages, 1, -1 do
            local msg = messages[i]
            local msgId = msg.id or tostring(msg.username) .. '|' .. tostring(msg.content) .. '|' .. tostring(msg.inserted_at)

            if not renderedMessageIds[msgId] then
                renderedMessageIds[msgId] = true

                local isLocal = msg.username == game:GetService('Players').LocalPlayer.Name
                local success, userId = pcall(function()
                    return game:GetService('Players'):GetUserIdFromNameAsync(msg.username)
                end)
                local pfp = nil

                if success and userId then
                    pfp = 'https://www.roblox.com/headshot-thumbnail/image?userId=' .. tostring(userId) .. '&width=150&height=150&format=png'
                end

                Menu:AddChatMessage(msg.username, msg.content, pfp, isLocal)
            end
        end
    end

