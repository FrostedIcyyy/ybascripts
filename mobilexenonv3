        local function updatePaletteFromInput(input)
            local ap, asz = palette.AbsolutePosition, palette.AbsoluteSize

            if asz.X == 0 or asz.Y == 0 then
                return
            end

            local rx = math.clamp((input.Position.X - ap.X) / asz.X, 0, 1)
            local ry = math.clamp((input.Position.Y - ap.Y) / asz.Y, 0, 1)

            Colorpicker.Saturation = rx
            Colorpicker.Value = 1 - ry
            selectionMarker.Position = UDim2.new(rx, 0, ry, 0)

            Colorpicker:Update()
        end
        local function updateHueFromInput(input)
            local ap, asz = hue.AbsolutePosition, hue.AbsoluteSize

            if asz.Y == 0 then
                return
            end

            local ry = math.clamp((input.Position.Y - ap.Y) / asz.Y, 0, 1)

            Colorpicker.Hue = ry
            hueMarker.Position = UDim2.new(0, -2, ry, -1)

            Colorpicker:Update()
        end

        function Colorpicker.Update(self)
            self.CurrentColor = Color3.fromHSV(self.Hue, self.Saturation, self.Value)
            previewButton.BackgroundColor3 = self.CurrentColor
            palette.BackgroundColor3 = Color3.fromHSV(self.Hue, 1, 1)

            if self.Flag then
                Menu.Flags[self.Flag] = self.CurrentColor
            end

            self.Callback(self.CurrentColor)

            if textboxInput then
                textboxInput.Text = self.CurrentColor:ToHex()
            end
        end
        function Colorpicker.SetOpen(self, open)
            if self.IsOpen == open then
                return
            end

            self.IsOpen = open

            if open then
                popupFrame.Visible = true
                popupFrame.BackgroundTransparency = 1
                popupScale.Scale = 0.7

                local TweenService = game:GetService'TweenService'

                TweenService:Create(popupFrame, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {BackgroundTransparency = 0}):Play()
                TweenService:Create(popupScale, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1}):Play()
                Menu:Tween(titleLabel, {
                    TextColor3 = Color3.fromRGB(204, 204, 204),
                })

                if not outsideClickConnection then
                    outsideClickConnection = UserInputService.InputBegan:Connect(function(input)
                        if input.UserInputType ~= Enum.UserInputType.MouseButton1 then
                            return
                        end
                        if not self.IsOpen then
                            return
                        end

                        local mp = input.Position
                        local fp, fs = popupFrame.AbsolutePosition, popupFrame.AbsoluteSize
                        local bp, bs = previewButton.AbsolutePosition, previewButton.AbsoluteSize
                        local inPopup = mp.X >= fp.X and mp.X <= fp.X + fs.X and mp.Y >= fp.Y and mp.Y <= fp.Y + fs.Y
                        local inButton = mp.X >= bp.X and mp.X <= bp.X + bs.X and mp.Y >= bp.Y and mp.Y <= bp.Y + bs.Y

                        if not inPopup and not inButton then
                            self:SetOpen(false)
                        end
                    end)
                end
            else
                local TweenService = game:GetService'TweenService'

                TweenService:Create(popupFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {BackgroundTransparency = 1}):Play()
                TweenService:Create(popupScale, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Scale = 0.7}):Play()
                Menu:Tween(titleLabel, {
                    TextColor3 = Color3.fromRGB(62, 62, 69),
                })
                task.delay(0.2, function()
                    if not self.IsOpen then
                        popupFrame.Visible = false
                    end
                end)

                if outsideClickConnection then
                    outsideClickConnection:Disconnect()

                    outsideClickConnection = nil
                end
            end
        end
        function Colorpicker.SetColor(self, color)
            if typeof(color) == 'string' then
                local ok, converted = pcall(Color3.fromHex, color)

                if ok then
                    color = converted
                else
                    return
                end
            end
            if typeof(color) ~= 'Color3' then
                return
            end

            self.Hue, self.Saturation, self.Value = color:ToHSV()
            self.CurrentColor = color
            selectionMarker.Position = UDim2.new(self.Saturation, 0, 1 - self.Value, 0)
            hueMarker.Position = UDim2.new(0, -2, self.Hue, -1)

            self:Update()
        end
        function Colorpicker.GetColor(self)
            return self.CurrentColor
        end
        function Colorpicker.Set(self, color)
            self:SetColor(color)
        end

        previewButton.InputBegan:Connect(function(input)
            if isClick(input) then
                Colorpicker:SetOpen(not Colorpicker.IsOpen)
            end
        end)
        palette.InputBegan:Connect(function(input)
            if isClick(input) then
                SlidingPalette = true

                updatePaletteFromInput(input)
            end
        end)
        palette.InputEnded:Connect(function(input)
            if isClick(input) then
                SlidingPalette = false
            end
        end)
        hue.InputBegan:Connect(function(input)
            if isClick(input) then
                SlidingHue = true

                updateHueFromInput(input)
            end
        end)
        hue.InputEnded:Connect(function(input)
            if isClick(input) then
                SlidingHue = false
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if isMove(input) then
                if SlidingPalette then
                    updatePaletteFromInput(input)
                end
                if SlidingHue then
                    updateHueFromInput(input)
                end
            end
        end)
        colorpickerFrame.MouseEnter:Connect(function()
            if not Colorpicker.IsOpen then
                Menu:Tween(titleLabel, {
                    TextColor3 = Color3.fromRGB(111, 111, 111),
                })
            end
        end)
        colorpickerFrame.MouseLeave:Connect(function()
            if not Colorpicker.IsOpen then
                Menu:Tween(titleLabel, {
                    TextColor3 = Color3.fromRGB(62, 62, 69),
                })
            end
        end)
        textboxInput.FocusLost:Connect(function()
            local text = textboxInput.Text

            if text:match('^#[0-9A-Fa-f]{6}$') then
                Colorpicker:SetColor(text)
            elseif text:match('^%d+,%s*%d+,%s*%d+$') then
                local r, g, b = text:match('(%d+),%s*(%d+),%s*(%d+)')

                r, g, b = tonumber(r), tonumber(g), tonumber(b)

                if r and g and b and r >= 0 and r <= 255 and g >= 0 and g <= 255 and b >= 0 and b <= 255 then
                    Colorpicker:SetColor(Color3.fromRGB(r, g, b))
                end
            end
        end)
        Colorpicker:SetColor(Colorpicker.Default)

        Menu.Flags[Colorpicker.Flag] = Colorpicker.CurrentColor

        Menu.Config:Register(Colorpicker.Flag, Colorpicker)

        return Colorpicker
    end

