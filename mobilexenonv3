    local function requestHttp(options)
        local req = http_request or request or (syn and syn.request) or (fluxus and fluxus.request)

        return req and req(options)
    end
    local function send_message(name, text)
        if #text > 80 then
            return
        end

        local data = {
            username = name,
            content = text,
        }

        requestHttp({
            Url = Menu.Chat.SupabaseURL .. '/rest/v1/messages',
            Method = 'POST',
            Headers = {
                ['Content-Type'] = 'application/json',
                apikey = Menu.Chat.SupabaseKey,
                Authorization = 'Bearer ' .. Menu.Chat.SupabaseKey,
            },
            Body = game:GetService('HttpService'):JSONEncode(data),
        })
    end
    local function fetch_messages()
        local res = requestHttp({
            Url = Menu.Chat.SupabaseURL .. '/rest/v1/messages?select=*&order=inserted_at.desc&limit=30',
            Method = 'GET',
            Headers = {
                apikey = Menu.Chat.SupabaseKey,
                Authorization = 'Bearer ' .. Menu.Chat.SupabaseKey,
            },
        })

        return res and game:GetService('HttpService'):JSONDecode(res.Body) or {}
    end
    local function containsBannedWord(msg)
        msg = msg:lower()

        for _, word in ipairs(Menu.Chat.BannedWords)do
            local pattern = '%f[%a]' .. word .. '%f[%A]'

            if string.find(msg, pattern) then
                return true
            end
        end

        return false
    end
