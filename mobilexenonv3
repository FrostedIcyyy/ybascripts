        function Dropdown.Toggle(self)
            if self.IsOpen then
                self:Close()
            else
                self:Open()
            end
        end
        function Dropdown.Set(self, value)
            if self.Multi then
                if type(value) == 'table' then
                    self.SelectedValues = {}

                    for _, v in ipairs(value)do
                        if table.find(self.Options, v) then
                            table.insert(self.SelectedValues, v)
                        end
                    end
                elseif type(value) == 'string' and table.find(self.Options, value) then
                    local index = table.find(self.SelectedValues, value)

                    if index then
                        table.remove(self.SelectedValues, index)
                    else
                        table.insert(self.SelectedValues, value)
                    end
                end

                for optionValue, optionFrame in pairs(self.OptionFrames)do
                    if table.find(self.SelectedValues, optionValue) then
                        Menu:Tween(optionFrame, self.selectedProperties)
                    else
                        Menu:Tween(optionFrame, self.unselectedProperties)
                    end
                end

                if #self.SelectedValues == 0 then
                    self.currentText.Text = '--'
                elseif #self.SelectedValues == 1 then
                    self.currentText.Text = self.SelectedValues[1]
                else
                    self.currentText.Text = #self.SelectedValues .. ' selected'
                end

                self.Value = self.SelectedValues
            else
                if table.find(self.Options, value) then
                    self.Value = value
                    self.currentText.Text = value

                    for optionValue, optionFrame in pairs(self.OptionFrames)do
                        if optionValue == value then
                            Menu:Tween(optionFrame, self.selectedProperties)
                        else
                            Menu:Tween(optionFrame, self.unselectedProperties)
                        end
                    end
                end
            end

            Menu.Flags[self.Flag] = self.Value

            self.Callback(self.Value)
        end
