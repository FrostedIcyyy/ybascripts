	function Slider.Set(self, value, noCallback)
		if type(value) ~= "number" then return end

		value = math.clamp(value, Slider.Min, Slider.Max)
		if Slider.Increment > 0 then
			value = math.floor((value - Slider.Min) / Slider.Increment + 0.5) * Slider.Increment + Slider.Min
		end
		value = tonumber(string.format("%.2f", value))
		Slider.Value = value

		local percent = (value - Slider.Min) / (Slider.Max - Slider.Min)

		if Slider._CurrentTween then
			Slider._CurrentTween:Cancel()
		end

		Slider._CurrentTween = TweenService:Create(indicator, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Size = UDim2.fromScale(percent, 1)
		})
		Slider._CurrentTween:Play()

		sliderValue.Text = tostring(value) .. Slider.ValueSuffix
		Library.Flags[Slider.Flag] = value
		if not noCallback then
			Slider.Callback(value)
		end
	end

	local isDragging = false
	local function updateSlider(input)
		local absPos = input.Position.X
		local barPos = sliderbar.AbsolutePosition.X
		local barSize = sliderbar.AbsoluteSize.X
		local percent = math.clamp((absPos - barPos) / barSize, 0, 1)
		local value = Slider.Min + ((Slider.Max - Slider.Min) * percent)
		Slider:Set(value)
	end

	sliderbar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch and active then
