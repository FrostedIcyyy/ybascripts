    local function fadeUIRoot(root, fadeIn, currentTween)
        if not root then
            return nil
        end
        if currentTween then
            pcall(function()
                currentTween:Cancel()
            end)
        end

        root.Visible = true

        local tw = game:GetService('TweenService'):Create(root, TweenInfo.new(fadeIn and 0.1 or 0.1, Enum.EasingStyle.Quad, fadeIn and Enum.EasingDirection.Out or Enum.EasingDirection.In), {
            GroupTransparency = fadeIn and 0 or 1,
        })

        tw:Play()

        if not fadeIn then
            tw.Completed:Once(function(s)
                if s == Enum.PlaybackState.Completed then
                    root.Visible = false
                    root.GroupTransparency = 0
                end
            end)
        end

        return tw
    end

