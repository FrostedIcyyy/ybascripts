            local RightArm = game:GetService('Players').LocalPlayer.Character:FindFirstChild('Right Arm')

            if not (LeftArm and RightArm) then
                return
            end
            if Tyrant.Visuals.CatchEffects.Type == 'Tyrant' then
                local TweenService = game:GetService('TweenService')
                local vfx = game:GetObjects('rbxassetid://97494051842514')[1]

                vfx.Parent = Child

                local emitters = {}

                for _, obj in ipairs(vfx:GetDescendants())do
                    if obj:IsA('ParticleEmitter') then
                        table.insert(emitters, obj)

                        obj.Enabled = true
                        obj.Transparency = NumberSequence.new(1)
                    end
                end

                local function setTransparency(value)
                    for _, emitter in ipairs(emitters)do
                        emitter.Transparency = NumberSequence.new(value)
                    end
                end

                local alpha = Instance.new('NumberValue')

                alpha.Value = 1

                alpha:GetPropertyChangedSignal('Value'):Connect(function()
                    setTransparency(alpha.Value)
                end)

                local fadeIn = TweenService:Create(alpha, TweenInfo.new(0.05, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Value = 0})

                fadeIn:Play()

                for _, emitter in ipairs(emitters)do
                    emitter:Emit(15)
                end

                task.delay(0.12, function()
                    local fadeOut = TweenService:Create(alpha, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Value = 1})

                    fadeOut:Play()
                    fadeOut.Completed:Wait()
                    vfx:Destroy()
                end)
            elseif Tyrant.Visuals.CatchEffects.Type == 'Smoke' then
                local Smoke = Instance.new('Smoke')

                Smoke.RiseVelocity = 5
                Smoke.Size = 7
