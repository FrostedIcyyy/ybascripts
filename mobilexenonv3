    local function SaveToSupabase(configName, configData)
        local shareCode = HttpService:GenerateGUID(false):gsub('%-', ''):sub(1, 8)
        local fullKey = tostring(game.PlaceId) .. '_' .. shareCode
        local body = HttpService:JSONEncode{
            share_code = fullKey,
            config_name = configName,
            data = configData,
        }
        local res = http_request{
            Url = Menu.Config.SUPABASE_URL .. '/rest/v1/shared_configs',
            Method = 'POST',
            Headers = {
                ['Content-Type'] = 'application/json',
                apikey = Menu.Config.SUPABASE_KEY,
                Authorization = 'Bearer ' .. Menu.Config.SUPABASE_KEY,
            },
            Body = body,
        }

        if res.StatusCode == 201 then
            Menu:ShowNotification({
                title = 'Share Code Created: ' .. shareCode,
                content = 'The share code has been copied to your clipboard!',
                duration = 3,
            })
            setclipboard(shareCode)
        else
        end
    end
    local function LoadFromSupabase(shareCode)
        local fullKey = tostring(game.PlaceId) .. '_' .. shareCode
        local res = http_request{
            Url = Menu.Config.SUPABASE_URL .. '/rest/v1/shared_configs?share_code=eq.' .. fullKey,
            Method = 'GET',
            Headers = {
                apikey = Menu.Config.SUPABASE_KEY,
                Authorization = 'Bearer ' .. Menu.Config.SUPABASE_KEY,
            },
        }
        local ok, data = pcall(HttpService.JSONDecode, HttpService, res.Body)

        if not ok or not data or not data[1] then
            return Menu:ShowNotification({
                title = 'Share Code Not Found',
                content = 'Could not find a config with that code.',
                duration = 2,
            })
        end

        local raw = data[1].data
        local decoded = type(raw) == 'string' and HttpService:JSONDecode(raw) or raw

        if not decoded then
            return
        end
        if decoded.__MenuAccent and type(decoded.__MenuAccent) == 'string' and #decoded.__MenuAccent == 6 then
            pcall(Menu.ChangeAccent, Menu, Color3.fromHex(decoded.__MenuAccent))
        end

        local toggleByFlag = {}

        for _, t in ipairs(Menu.Toggles)do
            if t.Flag then
                toggleByFlag[t.Flag] = t
            end
        end
        for flag, value in pairs(decoded)do
            if flag == '__MenuAccent' or flag == 'ConfigName' then
                continue
            end
            if type(value) == 'string' and #value == 6 and value:match('^%x+$') then
                value = Color3.fromHex(value)
            end

            Menu.Config.Configs[flag] = value

            if toggleByFlag[flag] then
                pcall(function()
                    toggleByFlag[flag]:Set(value)
                end)
            end

            local setter = Menu.Config.Setters[flag]

            if setter and type(setter) == 'function' then
                pcall(setter, value)
            end
        end

        Menu:ShowNotification({
            title = 'Loaded Cloud Config',
            content = 'Config loaded successfully!',
            duration = 2,
        })
    end

