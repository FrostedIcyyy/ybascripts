            end
        end
    end
    local function SmartFitAngle(startPos, targetPos, gravity, defenders, throwType, fixedPower)
        local cfg = QB.SmartFitConfig
        local flat = Vector3.new((targetPos - startPos).X, 0, (targetPos - startPos).Z)
        local distance = flat.Magnitude
        local dy = targetPos.Y - startPos.Y
        local dirXZ = distance > 0 and flat.Unit or Vector3.zero
        local FIXED_V = fixedPower
        local capMap = {
            Bullet = 25,
            Still = 30,
            Dive = 50,
            Dime = 55,
            Jump = 58,
            Mag = 65,
            Fade = 75,
        }
        local angleCap = capMap[throwType] or QB.MaxAngle

        if throwType == 'Bullet' or throwType == 'Still' then
            local manual = cfg.ManualLoftBonus or 0

            if cfg.JumpModeForBulletStill then
                local ja = throwType == 'Bullet' and (cfg.BulletJumpAngle or 28) or (cfg.StillJumpAngle or 35)

                return clamp(ja + manual, QB.MinAngle, angleCap)
            else
                local bonus = throwType == 'Bullet' and (cfg.BulletLoftBonus or 3) or (cfg.StillLoftBonus or 4)
                local angDeg = solveAngleForFixedV(gravity, distance, dy, FIXED_V, false)

                if not angDeg then
                    angDeg = throwType == 'Bullet' and 5 or 12
                end

                return clamp(math.floor(angDeg) + bonus + manual, QB.MinAngle, angleCap)
            end
        end

        local loftBonus = cfg.LoftBonus[throwType] or 0
        local defBonus = 0

        if #defenders == 1 then
            defBonus = cfg.DefenderLoft[1] or 4
        elseif #defenders == 2 then
            defBonus = cfg.DefenderLoft[2] or 8
        elseif #defenders >= 3 then
            defBonus = cfg.DefenderLoft[3] or 12
        end

        local function arcClearance(angleDeg)
            local ar = math.rad(angleDeg)
            local vxz = FIXED_V * math.cos(ar)
            local vy = FIXED_V * math.sin(ar)
            local tof = distance / math.max(vxz, 0.001)
            local velV = Vector3.new(dirXZ.X * vxz, vy, dirXZ.Z * vxz)
            local minClear = math.huge
            local samples = cfg.ArcSamples

            for i = 1, samples do
                local t = (i / samples) * tof
                local pos = startPos + velV * t + Vector3.new(0, -0.5 * gravity * t * t, 0)

                for _, hrp in ipairs(defenders)do
                    local dx = pos.X - hrp.Position.X
                    local dz = pos.Z - hrp.Position.Z

                    if dx * dx + dz * dz < cfg.DefenderHRadius * cfg.DefenderHRadius then
                        local clear = pos.Y - (hrp.Position.Y + cfg.DefenderReach)

                        if clear < minClear then
                            minClear = clear
                        end
                    end
                end
            end

            return minClear
        end

        local baseAngleDeg = solveAngleForFixedV(gravity, distance, dy, FIXED_V, false)

        if not baseAngleDeg then
            local tt2 = QB.ThrowTypes[throwType]
            local ideal = tt2 and tt2.AngleCurve and tt2.AngleCurve(distance) or {15, 22, 30}

            for _, ang in ipairs(ideal)do
                local v = solveVForAngle(gravity, distance, dy, ang)

                if v and v <= FIXED_V then
                    baseAngleDeg = ang

                    break
                end
            end

            baseAngleDeg = baseAngleDeg or 30
        end

        baseAngleDeg = clamp(math.floor(baseAngleDeg), QB.MinAngle, angleCap)

        local targetAngle = clamp(baseAngleDeg + loftBonus + defBonus + (cfg.ManualLoftBonus or 0), QB.MinAngle, angleCap)

        if #defenders == 0 then
            return targetAngle
        end
        if arcClearance(targetAngle) >= cfg.ClearanceMin then
            return targetAngle
        end

        local maxSearch = clamp(targetAngle + cfg.MaxNudge, QB.MinAngle, angleCap)

        for a = targetAngle + 1, maxSearch do
            if arcClearance(a) >= cfg.ClearanceMin then
                return a
            end
        end

        return targetAngle
    end
    local function CalculateOptimalThrow(startPos, targetPos, targetVelocity, gravity, target)
        local g = gravity
        local flat = Vector3.new((targetPos - startPos).X, 0, (targetPos - startPos).Z)
        local distance = flat.Magnitude
        local dy = targetPos.Y - startPos.Y

        if distance < 1e-3 then
            return Vector3.new(), Vector3.new(0, 1, 0), 0, 0.1, 45
        end

        local dirXZ = flat.Unit

        if QB.SmartFit then
            local cfg = QB.SmartFitConfig
            local autoType = AutoSelectThrowType(target, startPos)

            QB.CurrentThrowType = autoType

            local defenders = GetDefendersNearPath(startPos, targetPos, cfg.PathSearchRadius)
            local chosenPower

            if autoType == 'Bullet' or autoType == 'Still' then
                chosenPower = cfg.MaxPower
            elseif distance <= cfg.ShortDist then
                chosenPower = cfg.MaxPower

                for tp = cfg.MinPower, cfg.MaxPower, 5 do
                    if solveAngleForFixedV(gravity, distance, dy, tp, false) then
                        chosenPower = tp

                        break
                    end
                end
            elseif distance >= cfg.LongDist then
                chosenPower = cfg.MaxPower
            else
                local t2 = (distance - cfg.ShortDist) / (cfg.LongDist - cfg.ShortDist)

                chosenPower = clamp(math.floor((cfg.MinPower + t2 * (cfg.MaxPower - cfg.MinPower)) / 5) * 5, cfg.MinPower, cfg.MaxPower)
            end

            local angleDeg = SmartFitAngle(startPos, targetPos, gravity, defenders, autoType, chosenPower)
            local ar = math.rad(angleDeg)
            local vxz = chosenPower * math.cos(ar)
            local vy = chosenPower * math.sin(ar)
            local vel = Vector3.new(dirXZ.X * vxz, vy, dirXZ.Z * vxz)

            return vel, vel.Unit, chosenPower, distance / math.max(vxz, 1e-3), angleDeg
        end

        local function getIdealAngles(d)
            local tt2 = QB.ThrowTypes[QB.CurrentThrowType]

            if tt2 and tt2.AngleCurve then
                return tt2.AngleCurve(d)
            end
            if d < 15 then
                return {12, 16, 20}
            elseif d < 40 then
                return {18, 25, 32}
            elseif d < 80 then
                return {28, 35, 42}
            else
                return {20, 28, 35}
            end
        end

        if QB.CurrentThrowType == 'Still' then
            local cfg2 = QB.SmartFitConfig
            local manual = cfg2.ManualLoftBonus or 0
            local angDeg

            if cfg2.JumpModeForBulletStill then
                angDeg = QB.CurrentThrowType == 'Bullet' and (cfg2.BulletJumpAngle or 28) or (cfg2.StillJumpAngle or 35)
                angDeg = clamp(angDeg + manual, QB.MinAngle, QB.MaxAngle)
            else
                local bonus = QB.CurrentThrowType == 'Bullet' and (cfg2.BulletLoftBonus or 3) or (cfg2.StillLoftBonus or 4)
                local solved = solveAngleForFixedV(g, distance, dy, QB.MaxPower, false)

                angDeg = clamp(math.floor(solved or (QB.CurrentThrowType == 'Bullet' and 5 or 12)) + bonus + manual, QB.MinAngle, QB.MaxAngle)
            end

            local ar = math.rad(angDeg)
            local vxz = QB.MaxPower * math.cos(ar)
            local vy = QB.MaxPower * math.sin(ar)
            local vel = Vector3.new(dirXZ.X * vxz, vy, dirXZ.Z * vxz)

            return vel, vel.Unit, QB.MaxPower, distance / math.max(vxz, 1e-3), angDeg
        end
        if QB.BulletStillMaxPower and QB.CurrentThrowType == 'Bullet' then
            local V = QB.MaxPower
            local ad, ar = solveAngleForFixedV(g, distance, dy, V, false)

            if not ar then
                ar = CalculateLowAngleForHighSpeed(g, V, target)
            end

            local vxz = V * math.cos(ar)
            local vy = V * math.sin(ar)
            local vel = Vector3.new(dirXZ.X * vxz, vy, dirXZ.Z * vxz)

            return vel, vel.Unit, V, distance / math.max(vxz, 1e-3), math.deg(ar)
        end
        if QB.CurrentThrowType == 'Jump' then
            local al = getIdealAngles(distance)
            local chosenV, chosenA

            for _, ang in ipairs(al)do
                local v, A = solveVForAngle(g, distance, dy, ang)

                if v and v >= QB.MinPower and v <= QB.MaxPower then
                    chosenV = v
                    chosenA = A

                    break
                end
            end

            if not chosenV then
                local _, ar = solveAngleForFixedV(g, distance, dy, QB.MaxPower, true)

                chosenV = QB.MaxPower
                chosenA = ar or math.rad(45)
            end

            local vxz = chosenV * math.cos(chosenA)
            local vy = chosenV * math.sin(chosenA)
            local vel = Vector3.new(dirXZ.X * vxz, vy, dirXZ.Z * vxz)

            return vel, vel.Unit, chosenV, distance / math.max(vxz, 1e-3), math.deg(chosenA)
        end

        local effectiveAutoAngle = QB.AutoAngle or QB.CurrentThrowType == 'Bullet'

        if effectiveAutoAngle and QB.AutoPower then
            local chosenV, chosenA
            local isBullet = QB.CurrentThrowType == 'Bullet'
            local isFade = QB.CurrentThrowType == 'Fade'

            if isBullet then
                local aa = CalculateLowAngleForHighSpeed(g, QB.MaxPower, target)
                local v, A = solveVForAngle(g, distance, dy, math.deg(aa))

                if v and v >= QB.MinPower and v <= QB.MaxPower then
                    chosenV = v
                    chosenA = A
                end
            end
            if not chosenV then
                local al = getIdealAngles(distance)

                if isBullet then
                    table.sort(al, function(a, b)
                        return a < b
                    end)
                elseif isFade then
                    table.sort(al, function(a, b)
                        return a > b
                    end)
                end

                for _, ang in ipairs(al)do
                    local v, A = solveVForAngle(g, distance, dy, ang)

                    if v and v >= QB.MinPower and v <= QB.MaxPower then
                        chosenV = v
                        chosenA = A

                        if not isFade then
                            break
                        end
                    end
                end
            end
            if not chosenV then
                local _, ar = solveAngleForFixedV(g, distance, dy, QB.MaxPower, isFade or not isBullet)

                chosenV = QB.MaxPower
                chosenA = ar or math.rad(45)
            end

            local vxz = chosenV * math.cos(chosenA)
            local vy = chosenV * math.sin(chosenA)
            local vel = Vector3.new(dirXZ.X * vxz, vy, dirXZ.Z * vxz)

            return vel, vel.Unit, chosenV, distance / math.max(vxz, 1e-3), math.deg(chosenA)
        end
        if effectiveAutoAngle and not QB.AutoPower then
            local V = clamp(QB.ManualPower, QB.MinPower, QB.MaxPower)

            QB.ManualPower = V

            local ad, ar = solveAngleForFixedV(g, distance, dy, V)

            if not ad then
                local A = math.rad(clamp(QB.ManualAngleDeg, QB.MinAngle, QB.MaxAngle))
                local vxz = V * math.cos(A)
                local vy = V * math.sin(A)
                local vel = Vector3.new(dirXZ.X * vxz, vy, dirXZ.Z * vxz)

                return vel, vel.Unit, V, distance / math.max(vxz, 1e-3), math.deg(A)
            end

            QB.ManualAngleDeg = ad

            local vxz = V * math.cos(ar)
            local vy = V * math.sin(ar)
            local vel = Vector3.new(dirXZ.X * vxz, vy, dirXZ.Z * vxz)

            return vel, vel.Unit, V, distance / math.max(vxz, 1e-3), ad
        end
        if not effectiveAutoAngle and QB.AutoPower then
            local angDeg = clamp(QB.ManualAngleDeg, QB.MinAngle, QB.MaxAngle)

            QB.ManualAngleDeg = angDeg

            local v, ar = solveVForAngle(g, distance, dy, angDeg)

            if not v then
                v = QB.MaxPower
                ar = math.rad(angDeg)
            end

            v = clamp(v, QB.MinPower, QB.MaxPower)
            QB.ManualPower = v

            local vxz = v * math.cos(ar)
            local vy = v * math.sin(ar)
            local vel = Vector3.new(dirXZ.X * vxz, vy, dirXZ.Z * vxz)

            return vel, vel.Unit, v, distance / math.max(vxz, 1e-3), angDeg
        end

        local V = clamp(QB.ManualPower, QB.MinPower, QB.MaxPower)
        local Adeg = clamp(QB.ManualAngleDeg, QB.MinAngle, QB.MaxAngle)

        QB.ManualPower = V
        QB.ManualAngleDeg = Adeg

        local A = math.rad(Adeg)
        local vxz = V * math.cos(A)
        local vy = V * math.sin(A)
        local vel = Vector3.new(dirXZ.X * vxz, vy, dirXZ.Z * vxz)

        return vel, vel.Unit, V, distance / math.max(vxz, 1e-3), Adeg
    end

