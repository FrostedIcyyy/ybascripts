    Name = 'Gamepasses',
}

GamepassSection:Button{
    Name = 'Unlock Gamepasses',
    Callback = function()
        task.wait(2)

        local MarketplaceService = game:GetService('MarketplaceService')
        local LocalSave = require(game:GetService('ReplicatedFirst'):WaitForChild('LocalSave'))

        if setreadonly then
            pcall(function()
                setreadonly(LocalSave, false)
            end)
        end

        LocalSave.PlayerOwnsPass = function(_, passId, forceCheck)
            return true
        end

        task.spawn(function()
            while task.wait(2) do
                LocalSave.PurchaseFinished:Fire(123456, true)
            end
        end)
        MarketplaceService.PromptGamePassPurchaseFinished:Connect(function(LocalPlayer, passId, success)
            if LocalPlayer == LocalPlayer then
                LocalSave.PurchaseFinished:Fire(passId, true)
            end
        end)
        MarketplaceService.PromptSubscriptionPurchaseFinished:Connect(function(LocalPlayer, subscriptionId, success)
            if LocalPlayer == LocalPlayer then
                LocalSave.PurchaseFinished:Fire(subscriptionId, true)
            end
        end)
        Menu:CreateNotification({
            title = 'Gamepasses Unlocked',
            content = 'All gamepasses have been unlocked successfully.',
            duration = 5,
        })
    end,
}

