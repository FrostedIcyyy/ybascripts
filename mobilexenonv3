local updateUniform = function(replayCharacter, uniformOffsets)
    local uniform = replayCharacter:FindFirstChild('Uniform')

    if uniform and uniformOffsets then
        for partName, partData in next, uniformOffsets do
            local uniformPart = uniform:FindFirstChild(partName)
            local targetLimb = replayCharacter:FindFirstChild(partData[1])

            if uniformPart and targetLimb then
                local oldCF = uniformPart.CFrame
                local newCF = targetLimb.CFrame * partData[2]
                local deltaCF = newCF * oldCF:Inverse()

                uniformPart.CFrame = newCF

                for _, d in next, uniformPart:GetDescendants()do
                    if not d:IsA('BasePart') then
                        continue
                    end

                    d.CFrame = deltaCF * d.CFrame
                end
            end
        end
    end

    local head = replayCharacter:FindFirstChild('Head')

    if not head then
        return
    end

    for _, v in next, replayCharacter:GetDescendants()do
        if not v:IsA('BasePart') then
            continue
        end
        if v == head then
            continue
        end
        if v.Name:lower():find('head') or v.Name:lower():find('helmet') then
            local oldCF = v.CFrame
            local newCF = head.CFrame
            local deltaCF = newCF * oldCF:Inverse()

            v.CFrame = newCF

            for _, d in next, v:GetDescendants()do
