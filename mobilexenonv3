    local downRay = Ray.new(HRP.Position, Vector3.new(0, -500, 0))
    local hitPart, hitPosition = workspace:FindPartOnRay(downRay, Character, false, true)
    if hitPosition then
        HRP.CFrame = CFrame.new(hitPosition + Vector3.new(0, 5, 0))
    end
end

