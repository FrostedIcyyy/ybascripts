        local streakDot = moveUnit:Dot(fieldFwd)
        local towardQBDot = moveUnit:Dot(-flatToRecv)
        local lateral = Vector3.new(fieldFwd.Z, 0, -fieldFwd.X)
        local crossDot = math.abs(moveUnit:Dot(lateral))
        local cutTowardQB = moveUnit:Dot(-flatToRecv)
        local isJumping = velocity.Y > 4

        if towardQBDot > 0.45 then
            if dist < 20 then
                return 'Still'
            elseif dist < 35 then
                return 'Bullet'
            else
                return 'Dime'
            end
        end
        if crossDot > 0.55 and cutTowardQB > 0.05 then
            return 'Bullet'
        end
        if crossDot > 0.7 and math.abs(streakDot) < 0.5 then
            return 'Bullet'
        end
        if crossDot > 0.65 and streakDot > 0.3 and cutTowardQB < 0 then
            return 'Fade'
        end
        if crossDot > 0.55 and streakDot < 0.35 and cutTowardQB < -0.1 then
            return 'Dive'
        end
        if streakDot > 0.75 then
            if dist < 25 then
                return 'Bullet'
            elseif dist < 60 then
                return 'Dime'
            else
                return 'Mag'
            end
        end
        if isJumping then
            return 'Jump'
        end
        if streakDot > 0.35 and crossDot > 0.35 then
            return dist < 40 and 'Dime' or 'Mag'
        end

        return 'Dime'
    end
    local function GetDefendersNearPath(startPos, targetPos, searchRadius)
        searchRadius = searchRadius or 18

        local midX = (startPos.X + targetPos.X) * 0.5
        local midZ = (startPos.Z + targetPos.Z) * 0.5
        local sr2 = searchRadius * searchRadius
        local rushExclude2 = 64
        local defenders = {}

        for _, plr in ipairs(getCachedPlayers())do
            if plr ~= LocalPlayer and not isTeammate(plr) then
                local char = plr.Character
                local hrp = char and char:FindFirstChild('HumanoidRootPart')

                if hrp then
                    local qx = hrp.Position.X - startPos.X
                    local qz = hrp.Position.Z - startPos.Z

                    if qx * qx + qz * qz < rushExclude2 then
                        continue
                    end

                    local dx = hrp.Position.X - midX
                    local dz = hrp.Position.Z - midZ

                    if dx * dx + dz * dz < sr2 then
                        table.insert(defenders, hrp)
                    end
                end
            end
        end
        for _, npc in ipairs(getCachedNPCs())do
            if npc and npc.Parent then
                local hrp = npc:FindFirstChild('HumanoidRootPart')

                if hrp then
                    local qx = hrp.Position.X - startPos.X
                    local qz = hrp.Position.Z - startPos.Z

                    if qx * qx + qz * qz < rushExclude2 then
                        continue
                    end

                    local dx = hrp.Position.X - midX
                    local dz = hrp.Position.Z - midZ

                    if dx * dx + dz * dz < sr2 then
                        table.insert(defenders, hrp)
                    end
                end
            end
        end

        return defenders
    end
    local function GetDefenderAwareLead(startPos, targetPos, defenders, throwType)
        local cfg = QB.SmartFitConfig

        if #defenders == 0 then
            return Vector3.zero
        end

        local toTarget = targetPos - startPos
        local flatVec = Vector3.new(toTarget.X, 0, toTarget.Z)
        local totalDist = flatVec.Magnitude

        if totalDist < 0.1 then
            return Vector3.zero
        end

        local flatDir = flatVec.Unit
        local sideDir = Vector3.new(-flatDir.Z, 0, flatDir.X)
        local blockingDefs = {}

        for _, hrp in ipairs(defenders)do
            local toD = hrp.Position - startPos
            local along = Vector3.new(toD.X, 0, toD.Z):Dot(flatDir)

            if along > 5 and along < totalDist - 3 then
                local lat = Vector3.new(toD.X, 0, toD.Z):Dot(sideDir)

                table.insert(blockingDefs, {
                    hrp = hrp,
                    dist = along,
                    side = lat,
                })
            end
        end

        if #blockingDefs == 0 then
            return Vector3.zero
        end

        table.sort(blockingDefs, function(a, b)
            return a.dist < b.dist
        end)

        local lateralPush = Vector3.zero

        if #blockingDefs == 1 then
            lateralPush = (blockingDefs[1].side > 0 and -sideDir or sideDir) * cfg.LateralDodgePerDef
        elseif #blockingDefs >= 2 then
            local gapCenter = (blockingDefs[1].hrp.Position + blockingDefs[2].hrp.Position) * 0.5
            local gapDir = Vector3.new((targetPos - gapCenter).X, 0, (targetPos - gapCenter).Z)

            if gapDir.Magnitude > 0.1 then
                lateralPush = sideDir * (gapDir.Unit:Dot(sideDir) * cfg.LateralGapPush)
            end
        end
        if lateralPush.Magnitude > cfg.LateralDodgeMax then
            lateralPush = lateralPush.Unit * cfg.LateralDodgeMax
        end

        return lateralPush
    end
    local function updateDefenderHighlights(defenders, excludeModel)
        if not Tyrant.Throwing.Configurations.ShowDefenderHighlight then
            for model, hl in pairs(QB.DefenderHighlightCache)do
