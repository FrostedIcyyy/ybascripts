		local function saveThemeToFile(name)
			local themeData = Library.Theme[Library.SelectedTheme]
			local lines = {}
			for k, v in pairs(themeData) do
				table.insert(
					lines,
					k .. "=" .. math.floor(v.R * 255) .. "," .. math.floor(v.G * 255) .. "," .. math.floor(v.B * 255)
				)
			end
			writefile(name .. ".tyranttheme", table.concat(lines, "\n"))
		end

		local function loadThemeFromFile(name)
			local path = name .. ".tyranttheme"
			if not isfile(path) then
				return
			end
			local data = readfile(path)
			local theme = {}
			for line in data:gmatch("[^\r\n]+") do
				local k, rgb = line:match("([^=]+)=([^=]+)")
				if k and rgb then
					local r, g, b = rgb:match("(%d+),(%d+),(%d+)")
					if r and g and b then
						theme[k] = Color3.fromRGB(tonumber(r), tonumber(g), tonumber(b))
					end
				end
			end
			Library.Theme[name] = theme
			Library.SelectedTheme = name
			Library:SetTheme(name)
		end

