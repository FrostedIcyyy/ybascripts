		rgbBox.BackgroundTransparency = 1
		rgbBox.TextColor3 = Color3.fromRGB(255, 255, 255)
		rgbBox.ClearTextOnFocus = false
		rgbBox.Parent = popup
		Instance.new("UICorner", rgbBox)

		if not active then
			pickerBtn.BackgroundTransparency = 0.7
			title.TextTransparency = 0.7
			stroke.Transparency = 0.7
			preview.BackgroundTransparency = 0.7
		end

		local currentTitleTween = nil
			local function updateTitleColor(active)
				local targetColor = active and Color3.fromRGB(252, 253, 255) or Color3.fromRGB(71, 74, 93)

				if currentTitleTween then
					currentTitleTween:Cancel()
				end

				currentTitleTween = TweenService:Create(title, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
					TextColor3 = targetColor
				})
				currentTitleTween:Play()
			end


		rgbBox.FocusLost:Connect(function()
			local r, g, b = rgbBox.Text:match("(%d+),%s*(%d+),%s*(%d+)")
			if r and g and b then
				local newColor = Color3.fromRGB(tonumber(r), tonumber(g), tonumber(b))
				ColorPicker.Value = newColor
				preview.BackgroundColor3 = newColor
				palette.BackgroundColor3 = Color3.fromHSV(newColor:ToHSV())
				ColorPicker.Callback(newColor)
			end
		end)

		local function updatePaletteThumbSmooth(h, s, v)
			TweenService:Create(paletteThumb, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				Position = UDim2.new(math.clamp(s, 0.05, 0.95), -5, math.clamp(1 - v, 0.05, 0.95), -5),
			}):Play()
		end

		local function updateHueThumbSmooth(h)
			TweenService:Create(hueThumb, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				Position = UDim2.new(math.clamp(h, 0, 1), 0, 0.5, 0),
			}):Play()
		end

		local function updateAll()
			local r, g, b =
				math.floor(ColorPicker.Value.R * 255),
				math.floor(ColorPicker.Value.G * 255),
				math.floor(ColorPicker.Value.B * 255)
			rgbBox.Text = ("%d,%d,%d"):format(r, g, b)
			local h, s, v = ColorPicker.Value:ToHSV()
			palette.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
			updatePaletteThumbSmooth(h, s, v)
			updateHueThumbSmooth(h)
		end

		local draggingHue, draggingPalette = false, false

		local function getMouse()
			local pos = UserInputService:GetMouseLocation()
			return Vector2.new(pos.X, pos.Y - 36)
		end

		palette.InputBegan:Connect(function(input)
			if
				input.UserInputType == Enum.UserInputType.MouseButton1
				or input.UserInputType == Enum.UserInputType.Touch
			then
				draggingPalette = true
			end
		end)
		palette.InputEnded:Connect(function(input)
			if
				input.UserInputType == Enum.UserInputType.MouseButton1
				or input.UserInputType == Enum.UserInputType.Touch
			then
				draggingPalette = false
			end
		end)

		hueSlider.InputBegan:Connect(function(input)
			if
				input.UserInputType == Enum.UserInputType.MouseButton1
				or input.UserInputType == Enum.UserInputType.Touch
			then
				draggingHue = true
			end
		end)
		hueSlider.InputEnded:Connect(function(input)
			if
				input.UserInputType == Enum.UserInputType.MouseButton1
				or input.UserInputType == Enum.UserInputType.Touch
			then
				draggingHue = false
			end
		end)

		UserInputService.InputChanged:Connect(function(input)
			if
				input.UserInputType == Enum.UserInputType.MouseMovement
				or input.UserInputType == Enum.UserInputType.Touch
			then
				local mouse = getMouse()
				if draggingPalette then
					local pos = palette.AbsolutePosition
					local size = palette.AbsoluteSize
					local sx = math.clamp(mouse.X - pos.X, 0, size.X)
					local sy = math.clamp(mouse.Y - pos.Y, 0, size.Y)
					local h = ColorPicker.Value:ToHSV()
					local newColor = Color3.fromHSV(h, sx / size.X, 1 - sy / size.Y)
					ColorPicker.Value = newColor
					preview.BackgroundColor3 = newColor
					ColorPicker.Callback(newColor)
					updateAll()
				end
				if draggingHue then
					local pos = hueSlider.AbsolutePosition
					local size = hueSlider.AbsoluteSize
					local sx = math.clamp(mouse.X - pos.X, 0, size.X)
					local h = sx / size.X
					local _, s, v = ColorPicker.Value:ToHSV()
					local newColor = Color3.fromHSV(h, s, v)
					ColorPicker.Value = newColor
					preview.BackgroundColor3 = newColor
					ColorPicker.Callback(newColor)
					updateAll()
				end
			end
		end)


	preview.InputBegan:Connect(function(input)
		if
			input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch
		then
			if active then
			popup.Visible = not popup.Visible
			updateTitleColor(popup.Visible)

					if popup.Visible then
						local abs = preview.AbsolutePosition
						popup.Position = UDim2.new(
							0,
							math.clamp(abs.X, 0, workspace.CurrentCamera.ViewportSize.X - popup.Size.X.Offset),
							0,
							math.clamp(
								abs.Y + preview.AbsoluteSize.Y + 4,
								0,
								workspace.CurrentCamera.ViewportSize.Y - popup.Size.Y.Offset
							)
						)
						updateAll()
					end
				else
					Library:Notify("You must be on a non-limited (100% supported) executor to use this this feature.\nCheck the list at tyranthub.net/executors")
				end
				end
			end)

		UserInputService.InputBegan:Connect(function(input)
			if
				popup.Visible
				and (
					input.UserInputType == Enum.UserInputType.MouseButton1
					or input.UserInputType == Enum.UserInputType.Touch
				)
			then
				if not Library:IsMouseOverFrame(popup) and not Library:IsMouseOverFrame(preview) then
					popup.Visible = false
					updateTitleColor(false)
				end
			end
		end)

		ColorPicker.Callback(ColorPicker.Value)
		updateAll()

		function ColorPicker.Set(self, newColor)
			self.Value = newColor
			preview.BackgroundColor3 = newColor
			palette.BackgroundColor3 = Color3.fromHSV(newColor:ToHSV())
			updateAll()
			self.Callback(newColor)
		end

		return ColorPicker
	end

	function Tabs.Space(self, Properties)
		Properties = Properties or {}

		local spaceFrame = Instance.new("Frame", self.Elements.Left)
		spaceFrame.Name = "SpaceFrame"
		spaceFrame.BackgroundTransparency = 1
		spaceFrame.BorderSizePixel = 0
		spaceFrame.Size = UDim2.new(1, -12, 0, Properties.Height or 20)
		spaceFrame.Position = UDim2.fromScale(0, 0.0075)

		local uiPadding = Instance.new("UIPadding")
		uiPadding.PaddingTop = UDim.new(0, 8)
		uiPadding.PaddingBottom = UDim.new(0, 8)
		uiPadding.Parent = spaceFrame

		local uiCorner = Instance.new("UICorner")
		uiCorner.Parent = spaceFrame

		return spaceFrame
	end
end

