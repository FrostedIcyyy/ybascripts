        local lockKey = kb.LockOnKey
        local lockMatched = false

        if lockKey then
            if typeof(lockKey) == 'EnumItem' and lockKey.EnumType == Enum.UserInputType then
                lockMatched = input.UserInputType == lockKey
            elseif lockKey ~= Enum.KeyCode.Unknown then
                lockMatched = kc == lockKey
            end
        end
