    local function throwfb()
        if not QB.state then
            return
        end
        if not isPracticeMode() then
            local sf = ReplicatedStorage:FindFirstChild('Flags') and ReplicatedStorage.Flags:FindFirstChild('Status')

            if not sf or sf.Value ~= 'InPlay' then
                return
            end
        end

        local Football = Char:FindFirstChildOfClass('Tool')
        local tp = QB.ClosestPlr
        local thrp = ResolveHRP(tp)

        if not (Football and thrp) then
            return
        end
        if not isPracticeMode() and not isTeammate(tp) then
            return
        end
        if not OOB_INITIALIZED then
            initializeOOBParts()
        end

        local head = Char:FindFirstChild('Head')

        if not head then
            return
        end

        local start = head.CFrame.p
        local vel = thrp.Velocity
        local flat = Vector3.new(vel.X, 0, vel.Z)
        local moving = flat.Magnitude > 1.5
        local effVel = moving and vel or Vector3.zero
        local dir2 = moving and flat.Unit or Vector3.zero
        local throwType = QB.SmartFit and AutoSelectThrowType(tp, start) or QB.CurrentThrowType
        local fp = ComputePredicted(start, tp, thrp, throwType, effVel, moving, dir2)

        if QB.SmartFit then
            local nd = GetDefendersNearPath(start, fp, 20)

            fp = fp + GetDefenderAwareLead(start, fp, nd, throwType)
        end
        if QB.AntiOOB then
            fp = ClampPositionToInBounds(fp)
        end

        local _, direction, power = QB.CalculateOptimalThrow(start, fp, effVel, QB.FF2Grav, tp)

        QB.ThrowingTab.Direction = direction

        local RE = Football.Handle:FindFirstChild('RemoteEvent')

        if RE then
            throwremote(RE, start, start + direction * 10000, power)
        end
    end

