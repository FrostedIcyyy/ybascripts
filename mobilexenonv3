    function QB.updateHighlight(target)
        if not QB.currentHighlight or not QB.currentHighlight.Parent then
            QB.currentHighlight = Instance.new('Highlight')
            QB.currentHighlight.FillTransparency = 0.3
            QB.currentHighlight.OutlineTransparency = 0.4
            QB.currentHighlight.Parent = workspace

            table.insert(QB.Visuals, QB.currentHighlight)
        end

        local hl = QB.currentHighlight

        if not target then
            if hl.Enabled then
                hl.Enabled = false
            end

            return
        end

        local hrp = ResolveHRP(target)

        if not hrp then
            if hl.Enabled then
                hl.Enabled = false
            end

            return
        end

        local model = hrp:FindFirstAncestorOfClass('Model')

        if not model then
            if hl.Enabled then
                hl.Enabled = false
            end

            return
        end

        local fillCol = PRIMARY_COLOR
        local outlineCol = QB.TargetLocked and SECONDARY_COLOR or Color3.new(1, 1, 1)

        hl.FillColor = fillCol
        hl.OutlineColor = outlineCol

        if hl.Adornee ~= model then
            hl.Adornee = model
        end
        if not hl.Enabled then
            hl.Enabled = true
        end
    end

    local function ComputePredicted(start, targetPlayer, targetHrp, throwType, effectiveVelocity, moving, dir)
        local cfg = QB.SmartFitConfig
        local tt2 = QB.ThrowTypes[throwType]
        local leadOff = (not targetPlayer:IsA('Player')) and GetBotLeadOffset(targetPlayer) or Vector3.zero
        local hrpP = targetHrp.Position
        local flatDist = math.sqrt((hrpP.X - start.X) ^ 2 + (hrpP.Z - start.Z) ^ 2)
        local leadScale = math.clamp((flatDist - cfg.LeadScaleMinDist) / (cfg.LeadScaleMaxDist - cfg.LeadScaleMinDist), 0, 1)
        local _, _, _, rawTOF = QB.CalculateOptimalThrow(start, hrpP, effectiveVelocity, QB.FF2Grav, targetPlayer)
        local basePred = hrpP + effectiveVelocity * rawTOF * leadScale + leadOff
        local _, _, _, iterTOF = QB.CalculateOptimalThrow(start, basePred, effectiveVelocity, QB.FF2Grav, targetPlayer)

        basePred = hrpP + effectiveVelocity * iterTOF * leadScale + leadOff

        local leadDist = moving and ((tt2 and tt2.Lead or 0) * leadScale) or 0
        local route = CalculateRouteofPlayer(targetPlayer)
        local yOffset = QB.MasterLeads.Heights.HeadPlusTwo

        if not moving then
            yOffset = QB.MasterLeads.Heights.Chest
        elseif throwType == 'Bullet' and (route == 'Slant' or route == 'Comeback') then
            yOffset = QB.MasterLeads.Heights.Chest
        end

        return basePred + dir * leadDist + Vector3.new(0, yOffset, 0)
    end

