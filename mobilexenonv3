local function findOpp()
    for _, player in pairs(Players:GetPlayers()) do
        if player.Team ~= LocalPlayer.Team then
            local char = player.Character
            if char and char:FindFirstChild("Football") then
                return char
            end
        end
    end
    return nil
end

function FindClosestPlayer()
    if not Values or not Values:FindFirstChild("PossessionTag") then return nil end
    if LocalPlayer.Team and Values.PossessionTag.Value == LocalPlayer.Team.Name then return nil end

    local closestCharacter = nil
    local shortestDistance = math.huge

    local myCharacter = LocalPlayer.Character
    if not myCharacter or not myCharacter:FindFirstChild("HumanoidRootPart") then return nil end

    local myPosition = myCharacter.HumanoidRootPart.Position

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Team ~= LocalPlayer.Team then
            local char = player.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if hrp then
                local dist = (hrp.Position - myPosition).Magnitude
                if dist < shortestDistance then
                    shortestDistance = dist
                    closestCharacter = char
                end
            end
        end
    end

    return closestCharacter
end

function FindClosestCharacter()
	local MyCharacter = GetCharacter()
	local MyHRP = MyCharacter and MyCharacter:FindFirstChild("HumanoidRootPart")
	if not MyHRP then return nil end

	local closestCharacter = nil
	local shortestDistance = math.huge

	for _, player in pairs(game:GetService("Players"):GetPlayers()) do
		if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
			local char = player.Character
			local hrp = char:FindFirstChild("HumanoidRootPart")
			local dist = (MyHRP.Position - hrp.Position).Magnitude
			if dist < shortestDistance then
				shortestDistance = dist
				closestCharacter = char
			end
		end
	end

	return closestCharacter
end



