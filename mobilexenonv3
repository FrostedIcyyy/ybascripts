    function QB.getNearestWR()
        local cam = workspace.CurrentCamera
        local closest, closestDist2 = nil, math.huge
        local mX, mY

        if UserInputService.TouchEnabled then
            local vp = cam.ViewportSize

            mX, mY = vp.X * 0.5, vp.Y * 0.5
        else
            local mouse = LocalPlayer:GetMouse()

            mX, mY = mouse.X, mouse.Y
        end

        local function tryCandidate(obj, hrp)
            if not isPracticeMode() and not isTeammate(obj) then
                return
            end

            local pos, visible = cam:WorldToViewportPoint(hrp.Position)

            if not visible then
                return
            end

            local dx = pos.X - mX
            local dy2 = pos.Y - mY
            local d2 = dx * dx + dy2 * dy2

            if d2 < closestDist2 then
                closestDist2 = d2
                closest = obj
            end
        end

        for _, plr in ipairs(getCachedPlayers())do
            if plr ~= LocalPlayer then
                local char = plr.Character
                local hrp = char and char:FindFirstChild('HumanoidRootPart')

                if hrp then
                    tryCandidate(plr, hrp)
                end
            end
        end
        for _, npc in ipairs(getCachedNPCs())do
            if npc and npc.Parent then
                local hrp = npc:FindFirstChild('HumanoidRootPart')

                if hrp then
                    tryCandidate(npc, hrp)
                end
            end
        end

        return closest
    end
    function QB.UpdateInterception(landingPos, tof, receiver)
        local currentGuilty = {}
        local intercepted = false

        local function check(obj)
            local character = (obj:IsA('Player') and obj.Character) or obj

            if not character then
                return
            end

            local hrp = character:FindFirstChild('HumanoidRootPart')
            local hum = character:FindFirstChild('Humanoid')

            if not hrp or not hum then
                return
            end

            local dist = (hrp.Position - landingPos).Magnitude
            local relPos = (landingPos - hrp.Position).Unit
            local velDot = hrp.Velocity:Dot(relPos)
            local effSpeed = hum.WalkSpeed + math.max(velDot, 0)

            if (dist / effSpeed) - 0.31 <= tof or dist < 2 then
                intercepted = true
                currentGuilty[character] = true

                local hl = QB.InterceptionHighlightCache[character]

                if not hl or not hl.Parent then
                    hl = Instance.new('Highlight')
                    hl.FillColor = Color3.fromRGB(255, 0, 0)
                    hl.OutlineColor = Color3.new(0, 0, 0)
                    hl.FillTransparency = 0.3
                    hl.OutlineTransparency = 0.4
                    hl.Parent = character
                    QB.InterceptionHighlightCache[character] = hl

                    table.insert(QB.Visuals, hl)
                end
                if Tyrant.Throwing.Configurations.ShowDefenderHighlight then
                    if not hl.Enabled then
                        hl.Enabled = true
                    end
                else
                    if hl.Enabled then
                        hl.Enabled = false
                    end
                end
            end
        end

        for _, plr in ipairs(getCachedPlayers())do
            if plr ~= LocalPlayer and (not receiver or plr ~= receiver) then
                if isPracticeMode() or not isTeammate(plr) then
                    check(plr)
                end
            end
        end
        for _, npc in ipairs(getCachedNPCs())do
            if npc and npc.Parent and npc ~= receiver then
                check(npc)
            end
        end
        for model, hl in pairs(QB.InterceptionHighlightCache)do
            if not currentGuilty[model] and hl.Enabled then
                hl.Enabled = false
            end
        end

        return intercepted and 'YES' or 'NO'
    end

