			if Dropdown.Open then
				local isInside = false

				if dropdownList.Visible and Library:IsMouseOverFrame(dropdownList) then
					isInside = true
				end

				if Library:IsMouseOverFrame(dropdowncurrentframe) then
					isInside = true
				end

				if not isInside then
					Dropdown:Toggle(false)
				end
			end
		end
	end)


		function Dropdown.Refresh(self, newOptions)
			for _, child in pairs(optionHolder:GetChildren()) do
				if child:IsA("TextLabel") then
					child:Destroy()
				end
			end
			Dropdown.Options = newOptions
			for _, option in ipairs(Dropdown.Options) do
				Dropdown:AddOption(option)
			end
			local valueExists = false
			for _, option in ipairs(newOptions) do
				if option == Dropdown.Value then
					valueExists = true
					break
				end
			end
			if not valueExists and #newOptions > 0 then
				Dropdown:Set(newOptions[1])
			elseif not valueExists then
				Dropdown:Set("Select...")
			end
		end

		if Dropdown.Default ~= "Select..." then
			Dropdown:Set(Dropdown.Default)
		else
			Dropdown:Set(Dropdown.Options[1])
		end

		return Dropdown
	end

