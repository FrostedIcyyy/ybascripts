        local step = Slider.Decimals or 1
        local decimalPlaces = 0
        local s = tostring(step)

        if s:find('%.') then
            decimalPlaces = #s:match('%.(%d+)')
        end

        local format = string.format('%%.%df', decimalPlaces)

        Slider.Step = step

        local function UpdateDisplay(animated)
            local percentage = (Slider.Value - Slider.Min) / (Slider.Max - Slider.Min)
            local targetSize = UDim2.new(percentage, 5, 1, 0)

            game:GetService('TweenService'):Create(Slider.fill, TweenInfo.new(0.15, Enum.EasingStyle.Linear, Enum.EasingDirection.Out), {Size = targetSize}):Play()

            Slider.valueTextBox.Text = string.format(format, Slider.Value) .. Slider.Suffix
        end
        local function SetValue(value, isSliding)
            value = tonumber(value) or Slider.Min
            value = math.clamp(value, Slider.Min, Slider.Max)

            local step = Slider.Step > 0 and Slider.Step or 1

            value = math.floor((value / step) + 0.5) * step
            value = tonumber(string.format(format, value))
            Slider.Value = value

            UpdateDisplay(isSliding)

            Menu.Flags[Slider.Flag] = Slider.Value

            Slider.Callback(Slider.Value)
        end
        local function HandleSlide(input)
            local barStartX = line.AbsolutePosition.X
            local barSizeX = line.AbsoluteSize.X

            if barSizeX <= 0 then
                return
            end

            local mouseX = input.Position.X
            local clampedX = math.clamp(mouseX, barStartX, barStartX + barSizeX)
            local percentage = math.clamp((clampedX - barStartX) / barSizeX, 0, 1)

            SetValue(Slider.Min + (Slider.Max - Slider.Min) * percentage, true)
        end

        function Slider.Set(self, value)
            SetValue(value, false)
        end
        function Slider.GetValue(self)
            return self.Value
        end

        line.InputBegan:Connect(function(input)
            if isClick(input) then
                Slider.Sliding = true

                Menu:Tween(SliderName, {
                    TextColor3 = Color3.fromRGB(204, 204, 204),
                })
                HandleSlide(input)
            end
        end)
        game:GetService('UserInputService').InputEnded:Connect(function(input)
            if isClick(input) and Slider.Sliding then
                Slider.Sliding = false

                Menu:Tween(SliderName, {
                    TextColor3 = Color3.fromRGB(62, 62, 69),
                })
            end
        end)
        game:GetService('UserInputService').InputChanged:Connect(function(input)
            if Slider.Sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                HandleSlide(input)
            end
        end)
        Slider.valueTextBox.FocusLost:Connect(function()
            local text = Slider.valueTextBox.Text

            if Slider.Suffix ~= '' and text:sub(-#Slider.Suffix) == Slider.Suffix then
                text = text:sub(1, -#Slider.Suffix - 1)
            end

            local value = tonumber(text)

            if value then
                SetValue(value, false)
            else
                UpdateDisplay(false)
            end
        end)
        sliderframeee.MouseEnter:Connect(function()
            if not Slider.Sliding then
                Menu:Tween(SliderName, {
                    TextColor3 = Color3.fromRGB(111, 111, 111),
                })
            end
        end)
        sliderframeee.MouseLeave:Connect(function()
            if not Slider.Sliding then
                Menu:Tween(SliderName, {
                    TextColor3 = Color3.fromRGB(62, 62, 69),
                })
            end
        end)
        SetValue(Slider.Default, false)

        Menu.Flags[Slider.Flag] = Slider.Value

        Menu.Config:Register(Slider.Flag, Slider)
        table.insert(Menu.Sliders, Slider)

        return Slider
    end
