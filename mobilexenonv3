local function ClosestBall()
    local HRP = game:GetService('Players').LocalPlayer.Character:FindFirstChild('HumanoidRootPart')
    local closest, shortest = nil, math.huge

    for _, v in pairs(game:GetService('Workspace'):GetChildren())do
        if v.Name == 'Football' and v:IsA('BasePart') then
            local distance = (HRP.Position - v.Position).Magnitude

            if distance < shortest then
                closest = v
                shortest = distance
            end
        end
    end

    return closest, shortest
end
local function CatchBall(ball, catchpart)
    if not ball and catchpart then
        return
    end
    if Tyrant.Catching.Magnets.Mode == 'Exploit' then
        if Tyrant.Catching.Magnets.Delay > 0 then
            task.wait(Tyrant.Catching.Magnets.Delay)
        end

        firetouchinterest(catchpart, ball, 0)
        task.wait()
        firetouchinterest(catchpart, ball, 1)
    elseif Tyrant.Catching.Magnets.Mode == 'CFrame' then
        if Tyrant.Catching.Magnets.Delay > 0 then
            task.wait(Tyrant.Catching.Magnets.Delay)
        end

        ball.CFrame = catchpart.CFrame
