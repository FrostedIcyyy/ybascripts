function FindClosestPlayer()
    if not Values or not Values:FindFirstChild('PossessionTag') then
        return nil
    end
    if game:GetService('Players').LocalPlayer.Team and Values.PossessionTag.Value == game:GetService('Players').LocalPlayer.Team.Name then
        return nil
    end

    local closestCharacter = nil
    local shortestDistance = math.huge
    local myCharacter = game:GetService('Players').LocalPlayer.Character

    if not myCharacter or not myCharacter:FindFirstChild('HumanoidRootPart') then
        return nil
    end

    local myPosition = myCharacter.HumanoidRootPart.Position

    for _, player in ipairs(game:GetService('Players'):GetPlayers())do
        if player ~= game:GetService('Players').LocalPlayer and player.Team ~= game:GetService('Players').LocalPlayer.Team then
            local char = player.Character
            local hrp = char and char:FindFirstChild('HumanoidRootPart')

            if hrp then
                local dist = (hrp.Position - myPosition).Magnitude

                if dist < shortestDistance then
                    shortestDistance = dist
                    closestCharacter = char
                end
            end
        end
    end

    return closestCharacter
end
function FindClosestCharacter()
    local MyCharacter = GetCharacter()
    local MyHRP = MyCharacter and MyCharacter:FindFirstChild('HumanoidRootPart')

    if not MyHRP then
        return nil
    end

    local closestCharacter = nil
    local shortestDistance = math.huge

    for _, player in pairs(game:GetService('Players'):GetPlayers())do
        if player ~= game:GetService('Players').LocalPlayer and player.Character and player.Character:FindFirstChild('HumanoidRootPart') then
            local char = player.Character
            local hrp = char:FindFirstChild('HumanoidRootPart')
            local dist = (MyHRP.Position - hrp.Position).Magnitude

            if dist < shortestDistance then
                shortestDistance = dist
                closestCharacter = char
            end
        end
    end

    return closestCharacter
end
function beamProjectile(g, v0, x0, t1)
    local c = 0.125
    local p3 = 0.5 * g * t1 * t1 + v0 * t1 + x0
    local p2 = p3 - (g * t1 * t1 + v0 * t1) / 3
    local p1 = (c * g * t1 * t1 + 0.5 * v0 * t1 + x0 - c * (x0 + p3)) / (3 * c) - p2
    local curve0 = (p1 - x0).magnitude
    local curve1 = (p2 - p3).magnitude
    local b = (x0 - p3).unit
    local r1 = (p1 - x0).unit
    local u1 = r1:Cross(b).unit
    local r2 = (p2 - p3).unit
    local u2 = r2:Cross(b).unit

    b = u1:Cross(r1).unit

    local cf1 = CFrame.new(x0.x, x0.y, x0.z, r1.x, u1.x, b.x, r1.y, u1.y, b.y, r1.z, u1.z, b.z)
    local cf2 = CFrame.new(p3.x, p3.y, p3.z, r2.x, u2.x, b.x, r2.y, u2.y, b.y, r2.z, u2.z, b.z)

    return curve0, -curve1, cf1, cf2
end

