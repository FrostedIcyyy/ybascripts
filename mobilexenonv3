    for flag, value in pairs(Menu.Flags)do
        if typeof(value) == 'Color3' then
            configData[flag] = value:ToHex()
        else
            configData[flag] = value
        end
    end

    configData.__MenuAccent = Menu.Accent:ToHex()

    local success, error = pcall(function()
        writefile('configs/' .. configName .. '.cfg', game:GetService'HttpService':JSONEncode(configData))
    end)

    if success then
        return true
    else
        return false
    end
end
function Menu.Config.LoadConfigFromFile(self, configName)
    if not configName or configName == '' then
        warn'Config name is empty'

        return false
    end

    local success, error = pcall(function()
        local configData = readfile('configs/' .. configName .. '.cfg')
        local decoded = game:GetService'HttpService':JSONDecode(configData)

        for flag, value in pairs(decoded)do
            if flag == '__MenuAccent' then
                if type(value) == 'string' and string.match(value, '^[0-9A-Fa-f]{6}$') then
                    Menu:ChangeAccent(Color3.fromHex(value))
                end
            elseif flag ~= 'ConfigName' then
                if type(value) == 'string' and string.match(value, '^[0-9A-Fa-f]{6}$') then
                    value = Color3.fromHex(value)
                end

                Menu.Config.Configs[flag] = value

                local setter = Menu.Config.Setters[flag]

                if setter and type(setter) == 'function' then
                    setter(value)
                end
            end
        end
    end)

    if success then
        return true
    else
        return false
    end
end

Menu.tweenSpeed = 0.25
Menu.easingStyle = Enum.EasingStyle.Sine
Menu.easingDirection = Enum.EasingDirection.Out

local TweenService = game:GetService'TweenService'
local UserInputService = game:GetService'UserInputService'
local _ = Color3.fromRGB
local _ = UDim2.new
local _ = Vector2.new

local function isClick(input)
    return input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch
end
local function isMove(input)
    return input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch
end

function Menu.Tween(self, obj, props, duration, style, dir)
    local info = TweenInfo.new(duration or self.tweenSpeed, style or self.easingStyle, dir or self.easingDirection)
    local tween = TweenService:Create(obj, info, props)

    tween:Play()

    return tween
end
function Menu.setEffected(self, instances, props)
    for name, obj in instances do
        for prop, val in props[name]do
            self:Tween(obj, {[prop] = val})
        end
    end
end
function Menu.MakeDraggable(self, frame, dragHandle)
    local dragging = false
    local dragInput, dragStart, startPos

    local function update(input)
        local delta = input.Position - dragStart

        Menu:Tween(frame, {
            Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y),
        })
    end

    dragHandle.InputBegan:Connect(function(input)
        if Menu._mobileBtnDragging then
            return
        end
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position

            local connection

            connection = input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false

                    if connection then
                        connection:Disconnect()

                        connection = nil
                    end
                end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            update(input)
        end
    end)
end
function Menu.MakeResizeable(self, frame, minimum, maximum)
    local resizing, resizeStart = false
    local handle = Menu:Create('ImageButton', {
        Parent = frame,
        Image = 'rbxassetid://',
        AnchorPoint = Vector2.new(1, 1),
        Size = UDim2.new(0, 30, 0, 30),
        Position = UDim2.new(1, -6, 1, -6),
        Name = 'ResizeHandle',
        BackgroundTransparency = 1,
        ZIndex = 5,
        ImageColor3 = Menu.Accent,
    })
    local mobile = game:GetService('UserInputService').TouchEnabled and not game:GetService('UserInputService').KeyboardEnabled

    if mobile then
        handle.Visible = false
    else
        handle.InputBegan:Connect(function(input)
            if isClick(input) then
                resizing = true
                resizeStart = frame.Size - UDim2.new(0, input.Position.X, 0, input.Position.Y)
            end
        end)
        handle.InputEnded:Connect(function(input)
            if isClick(input) then
                resizing = false
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if resizing and isMove(input) then
                local screenSize = frame.Parent.AbsoluteSize
                local maxSize = maximum or Vector2.new(screenSize.X - 40, screenSize.Y - 40)
                local newSize = resizeStart + UDim2.new(0, input.Position.X, 0, input.Position.Y)
                local x = math.clamp(newSize.X.Offset, minimum.X, maxSize.X)
                local y = math.clamp(newSize.Y.Offset, minimum.Y, maxSize.Y)

                Menu:Tween(frame, {
                    Size = UDim2.new(0, x, 0, y),
                }, 0.17, Enum.EasingStyle.Quart)
            end
        end)
    end
end
function Menu.ChangeAccent(self, newAccent)
    Menu.Accent = newAccent
    Menu.ligticon.ImageColor3 = newAccent
    Menu.ToggleName.TextColor3 = newAccent
    Menu.Toggledescription.TextColor3 = newAccent

    for _, element in pairs(Menu._AccentElements)do
        if element.UpdateAccent then
            element:UpdateAccent(newAccent)
        end
    end
    for _, labelTitle in ipairs(Menu.Labels or {})do
        Menu:Tween(labelTitle, {TextColor3 = newAccent})
    end

    if Menu.CurrentWindow and Menu.CurrentWindow.Categories then
        for _, category in pairs(Menu.CurrentWindow.Categories)do
            for _, tab in pairs(category.Tabs)do
                if tab.ActiveProperties and tab.ActiveProperties.TabImage then
                    tab.ActiveProperties.TabImage.ImageColor3 = newAccent
                end
                if tab.Active and tab.EffectedInstances and tab.EffectedInstances.TabImage then
                    tab.EffectedInstances.TabImage.ImageColor3 = newAccent
                end
                if tab.HasSubtabs and tab.Subtabs then
                    for _, subtab in pairs(tab.Subtabs)do
                        if subtab.ActiveProperties then
                            if subtab.ActiveProperties.activatedline then
                                subtab.ActiveProperties.activatedline.BackgroundColor3 = newAccent
                            end
                            if subtab.HasIcon and subtab.ActiveProperties.TabImage then
                                subtab.ActiveProperties.TabImage.ImageColor3 = newAccent
                            end
                        end
                        if tab.Active and subtab.Active and subtab.EffectedInstances then
                            if subtab.EffectedInstances.activatedline then
                                subtab.EffectedInstances.activatedline.BackgroundColor3 = newAccent
                            end
                            if subtab.HasIcon and subtab.EffectedInstances.TabImage then
                                subtab.EffectedInstances.TabImage.ImageColor3 = newAccent
                            end
                        end
                    end
                end
            end
        end
    end

    for _, toggle in pairs(Menu.Toggles)do
        if toggle.enabledProperties and toggle.enabledProperties.TogglerHead then
            toggle.enabledProperties.TogglerHead.ImageColor3 = newAccent
        end
        if toggle.State and toggle.effectedInstances and toggle.effectedInstances.TogglerHead then
            toggle.effectedInstances.TogglerHead.ImageColor3 = newAccent
        end
    end
    for _, slider in pairs(Menu.Sliders)do
        if slider.fill then
            slider.fill.BackgroundColor3 = newAccent
        end
    end

    if Menu.settingbuttonicon and Menu.SettingsTab and Menu.SettingsTab.Active then
        Menu.settingbuttonicon.ImageColor3 = newAccent
    end
    if Menu.chatbuttonicon and Menu.ChatOpen then
        Menu.chatbuttonicon.ImageColor3 = newAccent
    end

    for _, notif in pairs(Menu.NotificationSystem.notifications)do
        if notif.progressBar then
            notif.progressBar.BackgroundColor3 = newAccent
        end
    end

    if Menu.themessagesss then
        for _, frame in pairs(Menu.themessagesss:GetDescendants())do
            if frame.Name == 'localmessage' then
                local messageBubble = frame:FindFirstChild('messagebubble', true)

                if messageBubble then
                    messageBubble.BackgroundColor3 = newAccent
                end

                local thelittlethingy = frame:FindFirstChild('thelittlethingy')

                if thelittlethingy then
                    thelittlethingy.ImageColor3 = newAccent
                end
            end
        end
    end
end
