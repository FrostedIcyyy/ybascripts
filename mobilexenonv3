    local function ProjectileBeam(g, v0, x0, t1)
        local c = 0.125
        local p3 = 0.5 * g * t1 * t1 + v0 * t1 + x0
        local p2 = p3 - (g * t1 * t1 + v0 * t1) / 3
        local p1 = (c * g * t1 * t1 + 0.5 * v0 * t1 + x0 - c * (x0 + p3)) / (3 * c) - p2
        local c0 = (p1 - x0).Magnitude
        local c1 = (p2 - p3).Magnitude
        local b = (x0 - p3).Unit
        local r1 = (p1 - x0).Unit
        local u1 = r1:Cross(b).Unit
        local r2 = (p2 - p3).Unit
        local u2 = r2:Cross(b).Unit

        b = u1:Cross(r1).Unit

        return c0, -c1, CFrame.new(x0.x, x0.y, x0.z, r1.x, u1.x, b.x, r1.y, u1.y, b.y, r1.z, u1.z, b.z), CFrame.new(p3.x, p3.y, p3.z, r2.x, u2.x, b.x, r2.y, u2.y, b.y, r2.z, u2.z, b.z)
    end
    local function solveVForAngle(g, distance, dy, angleDeg)
        local ar = math.rad(angleDeg)
        local cosA = math.cos(ar)

        if cosA == 0 then
            return nil
        end

        local denom = 2 * (cosA ^ 2) * (distance * math.tan(ar) - dy)

        if denom <= 0 then
            return nil
        end

        local v2 = (g * distance * distance) / denom

        if v2 <= 0 then
            return nil
        end

        return math.sqrt(v2), ar
    end
    local function solveAngleForFixedV(g, distance, dy, v, preferHigh)
        if distance <= 0 then
            return nil
        end

        local v2 = v * v
        local k = g * distance * distance / (2 * v2)
        local disc = distance * distance - 4 * k * (k + dy)

        if disc < 0 then
            return nil
        end

        local sqrtD = math.sqrt(disc)
        local t1 = (distance - sqrtD) / (2 * k)
        local t2 = (distance + sqrtD) / (2 * k)
        local ar = preferHigh and math.atan(t2) or math.atan(t1)
        local ad = math.deg(ar)

        if ad < 0 or ad > 88 then
            return nil
        end

        return clamp(ad, QB.MinAngle, QB.MaxAngle), math.rad(clamp(ad, QB.MinAngle, QB.MaxAngle))
    end
    local function CalculateRouteofPlayer(target)
        local hrp = ResolveHRP(target)

        if not hrp or not HumanoidRootPart then
            return 'Still'
        end

        local hum = (target:IsA('Player') and target.Character and target.Character:FindFirstChild('Humanoid')) or target:FindFirstChild('Humanoid')

        if not hum then
            return 'Still'
        end

        local moveDir = hum.MoveDirection

        if moveDir.Magnitude < 0.1 then
            return 'Still'
        end

        moveDir = moveDir.Unit

        local receiverToQB = -(hrp.Position - HumanoidRootPart.Position).Unit
        local fieldForward = Vector3.new(0, 0, hrp.Position.Z > HumanoidRootPart.Position.Z and 1 or -1)
        local streakAlignment = moveDir:Dot(fieldForward)
        local comebackAlignment = moveDir:Dot(receiverToQB)
        local lateral = Vector3.new(fieldForward.Z, 0, -fieldForward.X)
        local lateralAlignment = math.abs(moveDir:Dot(lateral))
        local towardQBFlat = Vector3.new(receiverToQB.X, 0, receiverToQB.Z)

        if towardQBFlat.Magnitude > 0 then
            towardQBFlat = towardQBFlat.Unit
        end

        local cutTowardQB = moveDir:Dot(towardQBFlat)

        if comebackAlignment > 0.75 then
            return 'Comeback'
        elseif lateralAlignment > 0.6 and cutTowardQB > 0.1 then
            return 'Slant'
        elseif lateralAlignment > 0.55 and streakAlignment < 0.35 then
            return 'Slant'
        elseif math.abs(streakAlignment) < 0.5 then
            return math.abs(streakAlignment) < 0.25 and 'Slant' or 'Post'
        elseif math.abs(streakAlignment) >= 0.8 then
            return 'Straight'
        end

        return 'Straight'
    end
    local function CalculateLowAngleForHighSpeed(gravity, speed, target)
        if speed <= 0 or not target then
            return math.rad(30)
        end

        local hrp = ResolveHRP(target)

        if not hrp then
            return math.rad(30)
        end

        local dist = ((HumanoidRootPart.Position - hrp.Position) * Vector3.new(1, 0, 1)).Magnitude
        local base = (dist * gravity) / (speed * speed)

        if base > 1 or base < -1 then
            return math.rad(15)
        end

        local route = CalculateRouteofPlayer(target)
        local mult

        if route == 'Comeback' then
            mult = dist < 150 and 0.52 or 0.47
        elseif route == 'Still' then
            mult = 0.6
        elseif route == 'Post' then
            mult = dist < 150 and 0.85 or 0.88
        else
            mult = dist < 150 and 0.87 or 0.9
        end

        return mult * math.asin(clamp(base, -1, 1))
    end
    local function AutoSelectThrowType(target, startPos)
        if not target then
            return 'Still'
        end

        local hrp = ResolveHRP(target)

        if not hrp then
            return 'Still'
        end

        local hum = (target:IsA('Player') and target.Character and target.Character:FindFirstChild('Humanoid')) or target:FindFirstChild('Humanoid')

        if not hum then
            return 'Still'
        end

        local velocity = hrp.Velocity
        local flatVel = Vector3.new(velocity.X, 0, velocity.Z)
        local speed = flatVel.Magnitude
        local moveDir = hum.MoveDirection

        if speed < 1.5 or moveDir.Magnitude < 0.1 then
            return 'Still'
        end

        local dist = (Vector3.new(hrp.Position.X, 0, hrp.Position.Z) - Vector3.new(startPos.X, 0, startPos.Z)).Magnitude
        local moveUnit = flatVel.Unit
        local toReceiver = hrp.Position - startPos
        local flatToRecv = Vector3.new(toReceiver.X, 0, toReceiver.Z)

        if flatToRecv.Magnitude > 0 then
            flatToRecv = flatToRecv.Unit
        end

        local fieldFwd = Vector3.new(0, 0, hrp.Position.Z > startPos.Z and 1 or -1)
        local streakDot = moveUnit:Dot(fieldFwd)
        local towardQBDot = moveUnit:Dot(-flatToRecv)
        local lateral = Vector3.new(fieldFwd.Z, 0, -fieldFwd.X)
        local crossDot = math.abs(moveUnit:Dot(lateral))
        local cutTowardQB = moveUnit:Dot(-flatToRecv)
        local isJumping = velocity.Y > 4

        if towardQBDot > 0.45 then
            if dist < 20 then
                return 'Still'
            elseif dist < 35 then
                return 'Bullet'
            else
                return 'Dime'
            end
        end
        if crossDot > 0.55 and cutTowardQB > 0.05 then
            return 'Bullet'
        end
        if crossDot > 0.7 and math.abs(streakDot) < 0.5 then
            return 'Bullet'
        end
        if crossDot > 0.65 and streakDot > 0.3 and cutTowardQB < 0 then
            return 'Fade'
        end
        if crossDot > 0.55 and streakDot < 0.35 and cutTowardQB < -0.1 then
            return 'Dive'
        end
        if streakDot > 0.75 then
            if dist < 25 then
                return 'Bullet'
            elseif dist < 60 then
                return 'Dime'
            else
                return 'Mag'
            end
        end
        if isJumping then
            return 'Jump'
        end
        if streakDot > 0.35 and crossDot > 0.35 then
            return dist < 40 and 'Dime' or 'Mag'
        end

        return 'Dime'
    end
    local function GetDefendersNearPath(startPos, targetPos, searchRadius)
        searchRadius = searchRadius or 18

        local midX = (startPos.X + targetPos.X) * 0.5
        local midZ = (startPos.Z + targetPos.Z) * 0.5
        local sr2 = searchRadius * searchRadius
        local rushExclude2 = 64
        local defenders = {}

        for _, plr in ipairs(getCachedPlayers())do
            if plr ~= LocalPlayer and not isTeammate(plr) then
                local char = plr.Character
                local hrp = char and char:FindFirstChild('HumanoidRootPart')

                if hrp then
                    local qx = hrp.Position.X - startPos.X
                    local qz = hrp.Position.Z - startPos.Z

                    if qx * qx + qz * qz < rushExclude2 then
                        continue
                    end

                    local dx = hrp.Position.X - midX
                    local dz = hrp.Position.Z - midZ

                    if dx * dx + dz * dz < sr2 then
                        table.insert(defenders, hrp)
                    end
                end
            end
        end
        for _, npc in ipairs(getCachedNPCs())do
            if npc and npc.Parent then
                local hrp = npc:FindFirstChild('HumanoidRootPart')

                if hrp then
                    local qx = hrp.Position.X - startPos.X
                    local qz = hrp.Position.Z - startPos.Z

                    if qx * qx + qz * qz < rushExclude2 then
                        continue
                    end

                    local dx = hrp.Position.X - midX
                    local dz = hrp.Position.Z - midZ

                    if dx * dx + dz * dz < sr2 then
                        table.insert(defenders, hrp)
                    end
                end
            end
        end

        return defenders
    end
    local function GetDefenderAwareLead(startPos, targetPos, defenders, throwType)
        local cfg = QB.SmartFitConfig

        if #defenders == 0 then
            return Vector3.zero
        end

        local toTarget = targetPos - startPos
        local flatVec = Vector3.new(toTarget.X, 0, toTarget.Z)
        local totalDist = flatVec.Magnitude

        if totalDist < 0.1 then
            return Vector3.zero
        end

        local flatDir = flatVec.Unit
        local sideDir = Vector3.new(-flatDir.Z, 0, flatDir.X)
        local blockingDefs = {}

        for _, hrp in ipairs(defenders)do
            local toD = hrp.Position - startPos
            local along = Vector3.new(toD.X, 0, toD.Z):Dot(flatDir)

            if along > 5 and along < totalDist - 3 then
                local lat = Vector3.new(toD.X, 0, toD.Z):Dot(sideDir)

                table.insert(blockingDefs, {
                    hrp = hrp,
                    dist = along,
                    side = lat,
                })
            end
        end

        if #blockingDefs == 0 then
            return Vector3.zero
        end

        table.sort(blockingDefs, function(a, b)
            return a.dist < b.dist
        end)

        local lateralPush = Vector3.zero

        if #blockingDefs == 1 then
            lateralPush = (blockingDefs[1].side > 0 and -sideDir or sideDir) * cfg.LateralDodgePerDef
        elseif #blockingDefs >= 2 then
            local gapCenter = (blockingDefs[1].hrp.Position + blockingDefs[2].hrp.Position) * 0.5
            local gapDir = Vector3.new((targetPos - gapCenter).X, 0, (targetPos - gapCenter).Z)

            if gapDir.Magnitude > 0.1 then
                lateralPush = sideDir * (gapDir.Unit:Dot(sideDir) * cfg.LateralGapPush)
            end
        end
        if lateralPush.Magnitude > cfg.LateralDodgeMax then
            lateralPush = lateralPush.Unit * cfg.LateralDodgeMax
        end

        return lateralPush
    end
