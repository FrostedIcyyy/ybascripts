        end
        if isTurning then
            turnAlpha += (dt / turnDuration)

            if turnAlpha >= 1 then
                isTurning = false
                currentAngle = targetAngle

                if turnDuration >= 0.5 then
                    freezeTime = 0.5
                end

                updateCamera(ball, currentAngle)
            else
                local tempAngle = currentAngle:Lerp(targetAngle, turnAlpha)

                updateCamera(ball, tempAngle)
