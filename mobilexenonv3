        function Keybind.Set(self, value)
            if type(value) == 'string' then
                if value == 'None' then
                    self.Key = nil
                    self.currentKeyLabel.Text = '[ . . . ]'
                else
                    local keyEnum = Enum.KeyCode[value]

                    if keyEnum then
                        self.Key = keyEnum
                        self.currentKeyLabel.Text = '[ ' .. value .. ' ]'
                    else
                        local mouseEnum = Enum.UserInputType[value]

                        if mouseEnum then
                            self.Key = mouseEnum
                            self.currentKeyLabel.Text = '[ ' .. value .. ' ]'
                        else
                            self.Key = nil
                            self.currentKeyLabel.Text = '[ . . . ]'
                        end
                    end
                end
            else
                self.Key = value

                if value == Enum.KeyCode.Backspace then
                    self.Key = nil
                    self.currentKeyLabel.Text = '[ . . . ]'
                else
                    local keyStr = tostring(value):gsub('Enum.KeyCode.', ''):gsub('Enum.UserInputType.', '')

                    self.currentKeyLabel.Text = '[ ' .. keyStr .. ' ]'
                end
            end

            self.Value = self.currentKeyLabel.Text:gsub('%[', ''):gsub('%]', ''):gsub('%s', '')

            if self.Value == '...' then
                self.Value = 'None'
            end

            Menu.Flags[self.Flag] = self.Value
        end
        function Keybind.GetValue(self)
            return self.Value
        end
        function Keybind.GetKey(self)
            return self.Key
        end
        function Keybind.StartListening(self)
            if self.IsListening then
                return
            end

            self.IsListening = true
            self.currentKeyLabel.Text = '[ . . . ]'

            Menu:Tween(self.currentKeyLabel, {
                TextColor3 = Menu.Accent,
            })
            Menu:Tween(KeybindName, {
                TextColor3 = Color3.fromRGB(111, 111, 111),
            })

            local connection

            connection = game:GetService'UserInputService'.InputBegan:Connect(function(input, gameProcessed)
                local isGamepad = input.UserInputType.Name:find('Gamepad')

                if gameProcessed and not isGamepad then
                    return
                end
                if input.UserInputType == Enum.UserInputType.Keyboard then
                    self:Set(input.KeyCode)

                    self.IsListening = false

                    Menu:Tween(self.currentKeyLabel, {
                        TextColor3 = Color3.fromRGB(62, 62, 69),
                    })
                    Menu:Tween(KeybindName, {
                        TextColor3 = Color3.fromRGB(62, 62, 69),
                    })
                    connection:Disconnect()
                elseif input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.MouseButton2 or input.UserInputType == Enum.UserInputType.MouseButton3 then
                    self:Set(input.UserInputType)

                    self.IsListening = false

                    Menu:Tween(self.currentKeyLabel, {
                        TextColor3 = Color3.fromRGB(62, 62, 69),
                    })
                    Menu:Tween(KeybindName, {
                        TextColor3 = Color3.fromRGB(62, 62, 69),
                    })
                    connection:Disconnect()
                elseif isGamepad and input.KeyCode ~= Enum.KeyCode.Unknown then
                    self:Set(input.KeyCode)

                    self.IsListening = false

                    Menu:Tween(self.currentKeyLabel, {
                        TextColor3 = Color3.fromRGB(62, 62, 69),
                    })
                    Menu:Tween(KeybindName, {
                        TextColor3 = Color3.fromRGB(62, 62, 69),
                    })
                    connection:Disconnect()
                end
            end)
        end

        keybindcurrentframe.InputBegan:Connect(function(input)
            if isClick(input) then
                Keybind:StartListening()
            end
        end)
        keybindframee.MouseEnter:Connect(function()
            if not Keybind.IsListening and not (Keybind.Mode == 'Toggle' and Keybind.State) then
                Menu:Tween(KeybindName, {
                    TextColor3 = Color3.fromRGB(111, 111, 111),
                })
            end
        end)
        keybindframee.MouseLeave:Connect(function()
            if not Keybind.IsListening and not (Keybind.Mode == 'Toggle' and Keybind.State) then
                Menu:Tween(KeybindName, {
                    TextColor3 = Color3.fromRGB(62, 62, 69),
                })
            end
        end)
        UserInputService.InputBegan:Connect(function(input, gameProcessed)
            local isGamepad = input.UserInputType.Name:find('Gamepad')

            if (gameProcessed and not isGamepad) or not Keybind.Key or Keybind.IsListening then
                return
            end

            local isKeyPressed = false

            if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == Keybind.Key then
                isKeyPressed = true
            elseif input.UserInputType == Keybind.Key then
                isKeyPressed = true
            elseif isGamepad and input.KeyCode == Keybind.Key then
                isKeyPressed = true
            end
            if isKeyPressed then
                if Keybind.Mode == 'Toggle' then
                    Keybind.State = not Keybind.State

                    Keybind.Callback(Keybind.State)

                    if Keybind.State then
                        Menu:Tween(KeybindName, {
                            TextColor3 = Color3.fromRGB(204, 204, 204),
                        })
                    else
                        Menu:Tween(KeybindName, {
                            TextColor3 = Color3.fromRGB(62, 62, 69),
                        })
                    end
                elseif Keybind.Mode == 'Hold' then
                    Keybind.State = true

                    Keybind.Callback(true)
                    Menu:Tween(KeybindName, {
                        TextColor3 = Color3.fromRGB(204, 204, 204),
                    })
                elseif Keybind.Mode == 'Button' then
                    Keybind.Callback(Keybind.Key)
                end
            end
        end)
        UserInputService.InputEnded:Connect(function(input, gameProcessed)
            local isGamepad = input.UserInputType.Name:find('Gamepad')

            if (gameProcessed and not isGamepad) or not Keybind.Key or Keybind.IsListening or Keybind.Mode ~= 'Hold' then
                return
            end

            local isKeyReleased = false

            if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == Keybind.Key then
                isKeyReleased = true
            elseif input.UserInputType == Keybind.Key then
                isKeyReleased = true
            elseif isGamepad and input.KeyCode == Keybind.Key then
                isKeyReleased = true
            end
            if isKeyReleased then
                Keybind.State = false

                Keybind.Callback(false)
                Menu:Tween(KeybindName, {
                    TextColor3 = Color3.fromRGB(62, 62, 69),
                })
            end
        end)
        Keybind:Set(Keybind.Default)

        Menu.Flags[Keybind.Flag] = Keybind.Value

        Menu.Config:Register(Keybind.Flag, Keybind)

        return Keybind
    end
