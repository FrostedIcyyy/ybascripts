            local notif = Menu.NotificationSystem.notificationsList[i]

            if notif and notif.frame and notif.frame.Parent and notif.isVisible then
                local targetY = -yOffset - notif.frame.AbsoluteSize.Y

                game:GetService'TweenService':Create(notif.frame, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
                    Position = UDim2.new(1, 0, 1, targetY),
                }):Play()

                yOffset = yOffset + notif.frame.AbsoluteSize.Y + padding
            end
        end
    end

