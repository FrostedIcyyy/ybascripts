		end
	end)

	sliderValue.FocusLost:Connect(function(enterPressed)
		if active then
			if active then
		updateTitleColor(false)
			end
		if enterPressed then
			local text = sliderValue.Text
			local suffixLength = #Slider.ValueSuffix
			local cleanedText = text
			if text:sub(-suffixLength) == Slider.ValueSuffix then
				cleanedText = text:sub(1, -suffixLength - 1)
			end
			local inputValue = tonumber(cleanedText)
			if inputValue then
				Slider:Set(inputValue)
			else
				sliderValue.Text = tostring(Slider.Value) .. Slider.ValueSuffix
			end
		end
	end
	end)
end

