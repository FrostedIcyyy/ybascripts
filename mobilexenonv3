			updateTitleColor(false)
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if (input.UserInputType == Enum.UserInputType.MouseMovement and active or input.UserInputType == Enum.UserInputType.Touch) and isDragging and active then
			updateSlider(input)
		end
	end)

	if active then
