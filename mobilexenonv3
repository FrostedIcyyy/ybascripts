			updateTitleColor(true)
			updateSlider(input)

			local connection
			connection = UserInputService.InputChanged:Connect(function(moveInput)
				if moveInput.UserInputType == Enum.UserInputType.MouseMovement or moveInput.UserInputType == Enum.UserInputType.Touch and active then
