            function Tab.Activate(self)
                if self == Menu.SettingsTab then
                    Menu:Tween(Menu.settingbuttonicon, {
                        ImageColor3 = Menu.Accent,
                    })
                else
                    Menu:Tween(Menu.settingbuttonicon, {
                        ImageColor3 = Color3.fromRGB(64, 63, 71),
                    })
                end

                for _, category in pairs(Window.Categories or {})do
                    for _, otherTab in pairs(category.Tabs)do
                        if otherTab ~= self then
                            otherTab.Active = false

                            if otherTab.EffectedInstances then
                                local eff = otherTab.EffectedInstances

                                if eff.UIStroke then
                                    eff.UIStroke.Enabled = false
                                end
                                if eff.Button then
                                    Menu:Tween(eff.Button, {BackgroundTransparency = 1})
                                end
                                if eff.TabImage then
                                    Menu:Tween(eff.TabImage, {
                                        ImageColor3 = Color3.fromRGB(64, 63, 71),
